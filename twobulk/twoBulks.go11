func groupByChromosome(stats []BSAstats) map[string][]BSAstats {
	byChr := map[string][]BSAstats{}
	for _, s := range stats {
		byChr[s.CHROM] = append(byChr[s.CHROM], s)
	}
	return byChr
}

func flattenMap(byChr map[string][]BSAstats) []BSAstats {
	var all []BSAstats
	for _, v := range byChr {
		all = append(all, v...)
	}
	return all
}

func writeSnpsTSV(snps []BSAstats, fname string) {
	f, _ := os.Create(fname)
	defer f.Close()
	fmt.Fprintln(f, "CHR\tPOS\tSNPiH\tSNPiL\tDELTA\tDELTAK\tED\tEDK\tG\tGPRIME\tBBLOGBF\tBBK\tEWMA")
	for _, s := range snps {
		fmt.Fprintf(f, "%s\t%d\t%.4f\t%.6f\t%.6f\t%.2f\t%.4f\n",
			s.CHROM, s.POS, s.HighSI, s.LowSI, s.DeltaSI, s.DeltaSIK,
			s.ED, s.EDK, s.Gstat, s.Gprime, s.BBLogBF, s.BBK, s.EWMA)
	}
}

func writeQTLsTSV(qtls []QTL, fname string) {
	f, _ := os.Create(fname)
	defer f.Close()
	fmt.Fprintln(f, "CHR\tSTART\tEND\tPEAK\tPEAK_GPRIME\tPEAK_BBK\tPEAK_EDK")
	for _, q := range qtls {
		fmt.Fprintf(f, "%s\t%d\t%d\t%d\t%.2f\t%.4f\t%.6f\n",
			q.Chr, q.Start, q.End, q.Peak, q.PeakGprime, q.PeakBBK, q.PeakEDK)
	}
}
