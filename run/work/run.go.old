package run

import (
	"compress/gzip"
	"fmt"
	"io"
	"maps"
	"os"
	"path/filepath"
	"slices"
	"strings"

	"github.com/AlecAivazis/survey/v2"
	"github.com/brentp/vcfgo"
	"github.com/fatih/color"
)

type AnalysisConfig struct {
	VCF string
	// Parameters for the analysis
	Population      string
	WindowSize      int
	StepSize        int
	Rep             int
	Alpha           float64
	MinQTLWidth     int64
	MergeDistance   int64
	OutputFile      string
	HighParentIdx   int
	HighParentName  string
	HighParentDepth int

	LowParentIdx   int
	LowParentName  string
	LowParentDepth int

	OneParentIdx   int
	OneParentName  string
	OneParentDepth int

	HighBulkIdx   int
	HighBulkName  string
	HighBulkDepth int
	HighBulkSize  int

	LowBulkIdx   int
	LowBulkName  string
	LowBulkDepth int
	LowBulkSize  int
	OneBulkIdx   int
	OneBulkName  string
	OneBulkDepth int
	OneBulkSize  int
}

func openVCF(path string) (io.Reader, func(), error) {
	f, err := os.Open(path)
	if err != nil {
		return nil, nil, err
	}

	cleanup := func() { f.Close() }

	if strings.HasSuffix(path, ".gz") {
		gz, err := gzip.NewReader(f)
		if err != nil {
			f.Close()
			return nil, nil, err
		}
		cleanup = func() {
			gz.Close()
			f.Close()
		}
		return gz, cleanup, nil
	}

	return f, cleanup, nil
}

// printAligned prints key-value pairs in a neatly aligned format.
func printAligned(title string, rows [][]string) {
	bold := color.New(color.Bold).SprintFunc()
	cyan := color.New(color.FgCyan).SprintFunc()

	fmt.Printf("\n%s\n\n", bold(cyan("  =================== "+title+" ===================")))
	for _, r := range rows {
		fmt.Printf("  %-22s %s\n", r[0]+":", r[1])
	}
	fmt.Println()
}

// printConfig prints a neatly aligned parameter summary.
func printConfig(cfg AnalysisConfig) {
	printAligned("Parameters", [][]string{
		{"VCF", cfg.VCF},
		{"Population", cfg.Population},
		{"Window size", fmt.Sprintf("%d", cfg.WindowSize)},
		{"Step size", fmt.Sprintf("%d", cfg.StepSize)},
		{"Simulations", fmt.Sprintf("%d", cfg.Rep)},
		{"Alpha", fmt.Sprintf("%v", cfg.Alpha)},
		{"Min QTL length", fmt.Sprintf("%d", cfg.MinQTLWidth)},
		{"Merge distance", fmt.Sprintf("%d", cfg.MergeDistance)},
		{"Output dir/prefix", cfg.OutputFile},
		{"High parent depth", fmt.Sprintf("%d", cfg.HighParentDepth)},
		{"Low parent depth", fmt.Sprintf("%d", cfg.LowParentDepth)},
		{"One parent depth", fmt.Sprintf("%d", cfg.OneParentDepth)},
		{"High bulk depth", fmt.Sprintf("%d", cfg.HighBulkDepth)},
		{"Low bulk depth", fmt.Sprintf("%d", cfg.LowBulkDepth)},
		{"One bulk depth", fmt.Sprintf("%d", cfg.OneBulkDepth)},
		{"High bulk size", fmt.Sprintf("%d", cfg.HighBulkSize)},
		{"Low bulk size", fmt.Sprintf("%d", cfg.LowBulkSize)},
		{"One bulk size", fmt.Sprintf("%d", cfg.OneBulkSize)},
	})
}

// printSelectionSummary prints a summary table of all resolved sample assignments.
func printSelectionSummary(cfg AnalysisConfig) {
	printAligned("Selection summary", [][]string{
		{"High parent", cfg.HighParentName},
		{"Low parent", cfg.LowParentName},
		{"One parent", cfg.OneParentName},
		{"High bulk", cfg.HighBulkName},
		{"Low bulk", cfg.LowBulkName},
		{"One bulk", cfg.OneBulkName},
	})
}

func selectSample(label string, sampleNamesDic map[int]string, exclude []string) (string, error) {
	// Build sorted choices, excluding used samples (but always keeping "None")
	keys := slices.Sorted(maps.Keys(sampleNamesDic))
	var choices []string
	for _, k := range keys {
		name := sampleNamesDic[k]
		if name == "None" || !slices.Contains(exclude, name) { // ← FIX: "None" bypasses exclude
			choices = append(choices, name)
		}
	}
	if len(choices) == 0 {
		return "", fmt.Errorf("no samples available to assign to %s", label)
	}

	var answer string
	prompt := &survey.Select{
		Message: "Select " + label + ":",
		Options: choices,
	}
	if err := survey.AskOne(prompt, &answer, survey.WithValidator(survey.Required)); err != nil {
		return "", err
	}

	// Remove chosen name from the map so it can't be picked again,
	// unless it's "None" which may be selected by multiple slots.
	if answer != "None" {
		for k, v := range sampleNamesDic {
			if v == answer {
				delete(sampleNamesDic, k)
				break
			}
		}
	}

	color.Green("  + %s -> %s\n", label, answer)
	return answer, nil
}

// validateOrReSelect checks if a configured sample name exists in the VCF.
// If not found, it prompts the user to re-select. If found (and not "None"),
// it removes the name from available choices.
func validateOrReSelect(label string, currentName string, sampleNames []string, sampleNamesDic map[int]string, exclude []string) (string, error) {
	if slices.Contains(sampleNames, currentName) {
		color.Green("  + %s -> %s\n", label, currentName)
		if currentName != "None" {
			for k, v := range sampleNamesDic {
				if v == currentName {
					delete(sampleNamesDic, k)
					break
				}
			}
		}
		return currentName, nil
	}

	color.Yellow("  ! %s %q not found in VCF -- please re-select.\n", label, currentName)
	return selectSample(label, sampleNamesDic, exclude)
}

// resolveParentSelection handles parent sample selection logic.
func resolveParentSelection(cfg *AnalysisConfig, sampleNames []string, sampleNamesDic map[int]string) error {
	color.Cyan("\n  --- Parent selection -------------------------------------------\n\n")

	// Both parents pre-configured: validate them
	if cfg.HighParentName != "" && cfg.LowParentName != "" {
		var err error
		cfg.HighParentName, err = validateOrReSelect("HIGH PARENT", cfg.HighParentName, sampleNames, sampleNamesDic, nil)
		if err != nil {
			return err
		}
		cfg.LowParentName, err = validateOrReSelect("LOW PARENT", cfg.LowParentName, sampleNames, sampleNamesDic, []string{cfg.HighParentName})
		if err != nil {
			return err
		}
		return nil
	}

	// No parents configured: interactive selection
	if cfg.HighParentName == "" && cfg.LowParentName == "" {
		var err error
		cfg.HighParentName, err = selectSample("HIGH PARENT", sampleNamesDic, nil)
		if err != nil {
			return err
		}
		cfg.LowParentName, err = selectSample("LOW PARENT", sampleNamesDic, []string{cfg.HighParentName})
		if err != nil {
			return err
		}
		return nil
	}

	// Partial configuration: not expected, handle gracefully
	return fmt.Errorf("incomplete parent configuration: both parents must be set or both left empty")
}

// resolveBulkSelection handles bulk sample selection logic.
func resolveBulkSelection(cfg *AnalysisConfig, sampleNamesDic map[int]string) error {
	color.Cyan("\n  --- Bulk selection ---------------------------------------------\n\n")

	if cfg.HighBulkName != "" || cfg.LowBulkName != "" || cfg.OneBulkName != "" {
		return fmt.Errorf("bulk samples must be selected interactively")
	}

	var err error
	cfg.HighBulkName, err = selectSample("HIGH BULK", sampleNamesDic,
		[]string{cfg.HighParentName, cfg.LowParentName})
	if err != nil {
		return err
	}
	cfg.LowBulkName, err = selectSample("LOW BULK", sampleNamesDic,
		[]string{cfg.HighParentName, cfg.LowParentName, cfg.HighBulkName})
	if err != nil {
		return err
	}
	return nil
}

// detectAnalysisMode determines which analysis pipeline to run based on configured samples.
func detectAnalysisMode(cfg AnalysisConfig) string {
	highSet := cfg.HighBulkName != "" && cfg.HighBulkName != "None"
	lowSet := cfg.LowBulkName != "" && cfg.LowBulkName != "None"
	highParSet := cfg.HighParentName != "" && cfg.HighParentName != "None"
	lowParSet := cfg.LowParentName != "" && cfg.LowParentName != "None"

	switch {
	case highSet && lowSet && !highParSet && !lowParSet:
		return "Bulks only (no parents)"
	case highSet && !lowSet && highParSet && lowParSet:
		return "One-bulk BSA-seq (HIGH bulk)"
	case !highSet && lowSet && highParSet && lowParSet:
		return "One-bulk BSA-seq (LOW bulk)"
	default:
		return "Two-bulk analysis"
	}
}

func Run(cfg AnalysisConfig) error {
	samples := []string{
		cfg.HighParentName, cfg.LowParentName, cfg.OneParentName,
		cfg.HighBulkName, cfg.LowBulkName, cfg.OneBulkName,
	}
	fmt.Printf("Samples: %v\n", samples)

	printConfig(cfg)

	f, cleanup, err := openVCF(cfg.VCF)
	if err != nil {
		panic(err)
	}
	defer cleanup()

	rdr, err := vcfgo.NewReader(f, false)
	if err != nil {
		panic(err)
	}

	sampleNames := rdr.Header.SampleNames
	sampleNamesDic := make(map[int]string)
	sampleNamesDic[0] = "None"
	for i, name := range sampleNames {
		sampleNamesDic[i+1] = name
	}

	if err := resolveParentSelection(&cfg, sampleNames, sampleNamesDic); err != nil {
		return err
	}
	if err := resolveBulkSelection(&cfg, sampleNamesDic); err != nil {
		return err
	}

	printSelectionSummary(cfg)

	// Ensure output directory exists
	if cfg.OutputFile != "" {
		dir := filepath.Dir(cfg.OutputFile)
		if dir != "." {
			if err := os.MkdirAll(dir, 0755); err != nil {
				return fmt.Errorf("failed to create output directory: %w", err)
			}
		}
	}

	fmt.Println()
	color.Cyan("  -> %s\n", detectAnalysisMode(cfg))
	fmt.Println()

	return nil
}
