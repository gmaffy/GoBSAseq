const (
	chartTheme  = types.ThemeWesteros
	chartWidth  = "900px"
	chartHeight = "500px"
	zSig        = 3.0
	zSugg       = 2.0
)

const posFormatter = `function(value) {
	if (value >= 1000000) { return (value / 1000000).toFixed(2) + ' Mb'; }
	if (value >= 1000)    { return (value / 1000).toFixed(1)    + ' kb'; }
	return value;
}`

type statThresholds struct {
	SmP95, SmP99       float64
	SmP95Neg, SmP99Neg float64
	ZP95, ZP99         float64
	ZP95Neg, ZP99Neg   float64
}

type plotStat struct {
	name          string
	smooth        func(stats.SmoothedStats) float64
	zscore        func(stats.SmoothedStats) float64
	thresholdKey  string
	bidirectional bool
	lineColor     string
	zLineWidth    float32
}

// CreatePlots writes interactive HTML charts to <output>/plots/ using smoothed
// statistics, empirical thresholds, and BRM blocks already produced by stats.
func CreatePlots(cfg utils.AnalysisConfig, bsaType string, sm []stats.SmoothedStats, brmBlocks []stats.BRMBlock) error {
	if len(sm) == 0 {
		return fmt.Errorf("no smoothed stats to plot")
	}

	hasHighBulk, hasLowBulk, hasBothBulks, hasOneBulk := bulkFlags(bsaType)
	plotStats := buildPlotStats(hasHighBulk, hasLowBulk, hasBothBulks, hasOneBulk)
	if len(plotStats) == 0 {
		return fmt.Errorf("no plottable statistics for bsaseq type %q", bsaType)
	}

	thresholdPath := filepath.Join(cfg.OutputDir, "stats", fmt.Sprintf("GoBSAseq.%s.thresholds.tsv", bsaType))
	thresholds, err := loadThresholds(thresholdPath)
	if err != nil {
		return err
	}

	plotsDir := filepath.Join(cfg.OutputDir, "plots")
	if err := os.MkdirAll(plotsDir, 0775); err != nil {
		return fmt.Errorf("create plots directory: %w", err)
	}

	byChrom := groupByChrom(sm)
	chroms := sortedChroms(byChrom)
	brmByChrom := groupBRMByChrom(brmBlocks)

	color.Cyan("\n============================ Generating HTML Plots (%s) =============================\n\n", bsaType)

	smoothedPage := components.NewPage()
	smoothedPage.SetLayout(components.PageFlexLayout)
	smoothedPage.PageTitle = fmt.Sprintf("GoBSAseq — Smoothed Statistics (%s)", bsaType)

	normalisedPage := components.NewPage()
	normalisedPage.SetLayout(components.PageFlexLayout)
	normalisedPage.PageTitle = fmt.Sprintf("GoBSAseq — Robust Z-score Overlay (%s)", bsaType)

	compositePage := components.NewPage()
	compositePage.SetLayout(components.PageFlexLayout)
	compositePage.PageTitle = fmt.Sprintf("GoBSAseq — Composite Signal (%s)", bsaType)

	maxZThresh := thresholds["MaxAbsZ"]

	for _, chrom := range chroms {
		points := byChrom[chrom]
		if len(points) == 0 {
			continue
		}

		x, smVals, zVals := extractSeriesData(points, plotStats)
		chromBRM := brmByChrom[chrom]

		for i, ps := range plotStats {
			t := thresholds[ps.thresholdKey]
			t99, t95 := t.SmP99, t.SmP95
			tm99, tm95 := t.SmP99Neg, t.SmP95Neg
			if ps.bidirectional && tm99 == 0 && tm95 == 0 && t99 != 0 {
				tm99, tm95 = -t99, -t95
			}
			smoothedPage.AddCharts(createInteractiveLineChart(
				chrom+" "+ps.name,
				x, smVals[i],
				t99, t95, tm99, tm95,
				ps.bidirectional && (tm99 != 0 || tm95 != 0),
				chromBRM,
			))
		}

		normalisedPage.AddCharts(createRobustZOverlayChart(chrom, x, plotStats, zVals, chromBRM))
		compositePage.AddCharts(createCompositeSignalChart(chrom, x, extractFloat(points, func(s stats.SmoothedStats) float64 { return s.MaxAbsZ }), maxZThresh, chromBRM))
	}

	smoothedPath := filepath.Join(plotsDir, bsaType+".smoothed.html")
	normalisedPath := filepath.Join(plotsDir, bsaType+".normalised.html")
	compositePath := filepath.Join(plotsDir, bsaType+".composite.html")

	if err := writeHTMLPage(smoothedPage, smoothedPath); err != nil {
		return err
	}
	if err := writeHTMLPage(normalisedPage, normalisedPath); err != nil {
		return err
	}
	if err := writeHTMLPage(compositePage, compositePath); err != nil {
		return err
	}

	color.Green("HTML plots written to %s", plotsDir)
	return nil
}

func buildPlotStats(hasHighBulk, hasLowBulk, hasBothBulks, hasOneBulk bool) []plotStat {
	var out []plotStat
	if hasHighBulk {
		out = append(out, plotStat{
			name: "HighSI", smooth: func(s stats.SmoothedStats) float64 { return s.SmHighSI },
			zscore: func(s stats.SmoothedStats) float64 { return s.ZHighSI },
			bidirectional: true, lineColor: "#1f77b4",
		})
	}
	if hasLowBulk {
		out = append(out, plotStat{
			name: "LowSI", smooth: func(s stats.SmoothedStats) float64 { return s.SmLowSI },
			zscore: func(s stats.SmoothedStats) float64 { return s.ZLowSI },
			bidirectional: true, lineColor: "#ff7f0e",
		})
	}
	if hasBothBulks {
		out = append(out,
			plotStat{name: "DeltaSI", smooth: func(s stats.SmoothedStats) float64 { return s.SmDeltaSI }, zscore: func(s stats.SmoothedStats) float64 { return s.ZDeltaSI }, thresholdKey: "DeltaSI", bidirectional: true, lineColor: "#2ca02c", zLineWidth: 3},
			plotStat{name: "Gstat", smooth: func(s stats.SmoothedStats) float64 { return s.SmGstat }, zscore: func(s stats.SmoothedStats) float64 { return s.ZGstat }, thresholdKey: "Gstat", lineColor: "#17becf"},
			plotStat{name: "ED4", smooth: func(s stats.SmoothedStats) float64 { return s.SmED }, zscore: func(s stats.SmoothedStats) float64 { return s.ZED }, thresholdKey: "ED", lineColor: "#d62728"},
			plotStat{name: "LOD", smooth: func(s stats.SmoothedStats) float64 { return s.SmLOD }, zscore: func(s stats.SmoothedStats) float64 { return s.ZLOD }, thresholdKey: "LOD", lineColor: "#9467bd"},
			plotStat{name: "BBLogBF", smooth: func(s stats.SmoothedStats) float64 { return s.SmBBLogBF }, zscore: func(s stats.SmoothedStats) float64 { return s.ZBBLogBF }, thresholdKey: "BBLogBF", lineColor: "#8c564b"},
		)
	}
	if hasOneBulk {
		out = append(out,
			plotStat{name: "AFDev", smooth: func(s stats.SmoothedStats) float64 { return s.SmAFDev }, zscore: func(s stats.SmoothedStats) float64 { return s.ZAFDev }, thresholdKey: "AFDev", bidirectional: true, lineColor: "#2ca02c", zLineWidth: 3},
			plotStat{name: "Gstat", smooth: func(s stats.SmoothedStats) float64 { return s.SmOneBulkG }, zscore: func(s stats.SmoothedStats) float64 { return s.ZOneBulkG }, lineColor: "#17becf"},
			plotStat{name: "LOD", smooth: func(s stats.SmoothedStats) float64 { return s.SmOneBulkLOD }, zscore: func(s stats.SmoothedStats) float64 { return s.ZOneBulkLOD }, lineColor: "#9467bd"},
			plotStat{name: "BBLogBF", smooth: func(s stats.SmoothedStats) float64 { return s.SmOneBulkBBLogBF }, zscore: func(s stats.SmoothedStats) float64 { return s.ZOneBulkBBLogBF }, lineColor: "#8c564b"},
		)
	}
	return out
}

func loadThresholds(path string) (map[string]statThresholds, error) {
	f, err := os.Open(path)
	if err != nil {
		return nil, fmt.Errorf("open thresholds %s: %w", path, err)
	}
	defer f.Close()

	out := make(map[string]statThresholds)
	sc := bufio.NewScanner(f)
	if !sc.Scan() {
		return nil, fmt.Errorf("empty thresholds file %s", path)
	}

	for sc.Scan() {
		fields := strings.Split(sc.Text(), "\t")
		if len(fields) < 5 {
			continue
		}
		name := fields[0]
		t := statThresholds{
			SmP95: parseFloat(fields[1]),
			SmP99: parseFloat(fields[2]),
			ZP95:  parseFloat(fields[3]),
			ZP99:  parseFloat(fields[4]),
		}
		if len(fields) > 5 && fields[5] != "" {
			t.SmP95Neg = parseFloat(fields[5])
		}
		if len(fields) > 6 && fields[6] != "" {
			t.SmP99Neg = parseFloat(fields[6])
		}
		if len(fields) > 7 && fields[7] != "" {
			t.ZP95Neg = parseFloat(fields[7])
		}
		if len(fields) > 8 && fields[8] != "" {
			t.ZP99Neg = parseFloat(fields[8])
		}
		out[name] = t
	}
	if err := sc.Err(); err != nil {
		return nil, fmt.Errorf("read thresholds %s: %w", path, err)
	}
	return out, nil
}

func parseFloat(s string) float64 {
	if s == "" {
		return 0
	}
	v, _ := strconv.ParseFloat(s, 64)
	return v
}

func bulkFlags(bsaType string) (hasHighBulk, hasLowBulk, hasBothBulks, hasOneBulk bool) {
	hasHighBulk = strings.Contains(bsaType, "hb") || strings.Contains(bsaType, "2b")
	hasLowBulk = strings.Contains(bsaType, "lb") || strings.Contains(bsaType, "2b")
	hasBothBulks = hasHighBulk && hasLowBulk
	hasOneBulk = hasHighBulk != hasLowBulk
	return
}

func groupByChrom(sm []stats.SmoothedStats) map[string][]stats.SmoothedStats {
	out := make(map[string][]stats.SmoothedStats)
	for _, s := range sm {
		out[s.CHROM] = append(out[s.CHROM], s)
	}
	for chrom := range out {
		sort.Slice(out[chrom], func(i, j int) bool { return out[chrom][i].POS < out[chrom][j].POS })
	}
	return out
}

func sortedChroms(byChrom map[string][]stats.SmoothedStats) []string {
	chroms := make([]string, 0, len(byChrom))
	for c := range byChrom {
		chroms = append(chroms, c)
	}
	sort.Strings(chroms)
	return chroms
}

func groupBRMByChrom(blocks []stats.BRMBlock) map[string][]stats.BRMBlock {
	out := make(map[string][]stats.BRMBlock)
	for _, b := range blocks {
		out[b.Chrom] = append(out[b.Chrom], b)
	}
	return out
}

func extractSeriesData(points []stats.SmoothedStats, plotStats []plotStat) ([]int64, [][]float64, [][]float64) {
	n := len(points)
	x := make([]int64, n)
	smVals := make([][]float64, len(plotStats))
	zVals := make([][]float64, len(plotStats))
	for i := range plotStats {
		smVals[i] = make([]float64, n)
		zVals[i] = make([]float64, n)
	}
	for i, s := range points {
		x[i] = s.POS
		for j, ps := range plotStats {
			smVals[j][i] = ps.smooth(s)
			zVals[j][i] = ps.zscore(s)
		}
	}
	return x, smVals, zVals
}

func extractFloat(points []stats.SmoothedStats, fn func(stats.SmoothedStats) float64) []float64 {
	out := make([]float64, len(points))
	for i, s := range points {
		out[i] = fn(s)
	}
	return out
}

func commonGlobalOpts(title, subtitle, yLabel string, bidirectional bool) []charts.GlobalOpts {
	yMin := opts.Float(0.0)
	if bidirectional {
		yMin = nil
	}
	return []charts.GlobalOpts{
		charts.WithInitializationOpts(opts.Initialization{
			Theme:  chartTheme,
			Width:  chartWidth,
			Height: chartHeight,
		}),
		charts.WithTitleOpts(opts.Title{
			Title:    title,
			Subtitle: subtitle,
			Left:     "center",
			Top:      "1%",
		}),
		charts.WithXAxisOpts(opts.XAxis{
			Name:         "Genomic Position",
			NameLocation: "middle",
			NameGap:      35,
			AxisLabel: &opts.AxisLabel{
				Rotate:    30,
				Formatter: opts.FuncOpts(posFormatter),
			},
		}),
		charts.WithYAxisOpts(opts.YAxis{
			Name:         yLabel,
			NameLocation: "middle",
			NameGap:      55,
			Min:          yMin,
			SplitLine:    &opts.SplitLine{Show: opts.Bool(true)},
		}),
		charts.WithDataZoomOpts(
			opts.DataZoom{Type: "slider", XAxisIndex: []int{0}, Start: 0, End: 100},
			opts.DataZoom{Type: "inside", XAxisIndex: []int{0}},
		),
		charts.WithLegendOpts(opts.Legend{
			Show:   opts.Bool(true),
			Top:    "9%",
			Left:   "center",
			Type:   "scroll",
			Orient: "horizontal",
		}),
		charts.WithToolboxOpts(opts.Toolbox{
			Show:  opts.Bool(true),
			Right: "2%",
			Feature: &opts.ToolBoxFeature{
				SaveAsImage: &opts.ToolBoxFeatureSaveAsImage{Show: opts.Bool(true), Title: "Save PNG"},
				DataZoom:    &opts.ToolBoxFeatureDataZoom{Show: opts.Bool(true), Title: map[string]string{"zoom": "Zoom", "back": "Reset"}},
				Restore:     &opts.ToolBoxFeatureRestore{Show: opts.Bool(true), Title: "Reset"},
			},
		}),
		charts.WithGridOpts(opts.Grid{
			Left:         "8%",
			Right:        "4%",
			Top:          "20%",
			Bottom:       "14%",
			ContainLabel: opts.Bool(true),
		}),
	}
}

func createInteractiveLineChart(title string, x []int64, y []float64, t99, t95, tm99, tm95 float64, hasNegativeThresh bool, brmBlocks []stats.BRMBlock) *charts.Line {
	subtitle := fmt.Sprintf("p99 threshold: %.4f  |  p95 threshold: %.4f  |  shaded: BRM blocks", t99, t95)
	line := charts.NewLine()
	line.SetGlobalOptions(commonGlobalOpts(title, subtitle, "Value", hasNegativeThresh)...)

	line.SetGlobalOptions(charts.WithTooltipOpts(opts.Tooltip{
		Show:        opts.Bool(true),
		Trigger:     "axis",
		AxisPointer: &opts.AxisPointer{Type: "cross"},
	}))

	n := len(y)
	yData := make([]opts.LineData, n)
	for i, v := range y {
		yData[i] = opts.LineData{Value: v}
	}
	statOpts := []charts.SeriesOpts{
		charts.WithLineChartOpts(opts.LineChart{Smooth: opts.Bool(true)}),
		charts.WithLineStyleOpts(opts.LineStyle{Width: 2.5, Color: "#1f77b4"}),
		charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
	}
	statOpts = append(statOpts, brmBlockMarkAreaOpts(brmBlocks, x)...)

	line.SetXAxis(positionLabels(x)).
		AddSeries("Statistic", yData, statOpts...)

	if t99 != 0 || t95 != 0 {
		y99 := make([]opts.LineData, n)
		y95 := make([]opts.LineData, n)
		for i := range y {
			y99[i] = opts.LineData{Value: t99}
			y95[i] = opts.LineData{Value: t95}
		}
		line.AddSeries("p99", y99,
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.8, Color: "#e74c3c"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		).AddSeries("p95", y95,
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.4, Color: "#f39c12"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		)
	}

	if hasNegativeThresh && (tm99 != 0 || tm95 != 0) {
		ym99 := make([]opts.LineData, n)
		ym95 := make([]opts.LineData, n)
		for i := range y {
			ym99[i] = opts.LineData{Value: tm99}
			ym95[i] = opts.LineData{Value: tm95}
		}
		line.AddSeries("p99 valley", ym99,
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.8, Color: "#e74c3c"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		).AddSeries("p95 valley", ym95,
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.4, Color: "#f39c12"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		)
	}

	return line
}

func createRobustZOverlayChart(chrom string, x []int64, plotStats []plotStat, zVals [][]float64, brmBlocks []stats.BRMBlock) *charts.Line {
	title := chrom + " — Robust Z-score Overlay"
	subtitle := "Genome-wide robust Z-scores. z = ±2 suggestive · z = ±3 significant. Shaded bands: BRM blocks."

	line := charts.NewLine()
	line.SetGlobalOptions(commonGlobalOpts(title, subtitle, "Robust Z-score", true)...)

	n := len(x)
	mkRef := func(val float64) []opts.LineData {
		d := make([]opts.LineData, n)
		for i := range d {
			d[i] = opts.LineData{Value: val}
		}
		return d
	}

	zeroOpts := []charts.SeriesOpts{
		charts.WithLineStyleOpts(opts.LineStyle{Type: "solid", Width: 1, Color: "#bdc3c7"}),
		charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
	}
	zeroOpts = append(zeroOpts, brmBlockMarkAreaOpts(brmBlocks, x)...)

	line.SetXAxis(positionLabels(x)).
		AddSeries("z=0", mkRef(0), zeroOpts...).
		AddSeries("z=+2 (sugg.)", mkRef(zSugg),
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.4, Color: "#f39c12"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		).
		AddSeries("z=+3 (sig.)", mkRef(zSig),
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.8, Color: "#e74c3c"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		).
		AddSeries("z=-2 (sugg.)", mkRef(-zSugg),
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.4, Color: "#f39c12"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		).
		AddSeries("z=-3 (sig.)", mkRef(-zSig),
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.8, Color: "#e74c3c"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		)

	for i, ps := range plotStats {
		width := float32(2.0)
		if ps.zLineWidth > 0 {
			width = ps.zLineWidth
		}
		col := ps.lineColor
		if col == "" {
			col = statColor(ps.name)
		}
		line.AddSeries(ps.name, floatSliceToLineData(zVals[i]),
			charts.WithLineChartOpts(opts.LineChart{Smooth: opts.Bool(true)}),
			charts.WithLineStyleOpts(opts.LineStyle{Width: width, Color: col}),
			charts.WithItemStyleOpts(opts.ItemStyle{Color: col, Opacity: opts.Float(0)}),
		)
	}
	return line
}

func createCompositeSignalChart(chrom string, x []int64, composite []float64, thresh statThresholds, brmBlocks []stats.BRMBlock) *charts.Line {
	title := chrom + " — Composite Signal (max |Z|)"
	subtitle := "Max absolute robust Z-score per variant. z = 2 suggestive · z = 3 significant. Shaded bands: BRM blocks."

	z2 := zSugg
	z3 := zSig
	if thresh.ZP95 > 0 {
		z2 = thresh.ZP95
	}
	if thresh.ZP99 > 0 {
		z3 = thresh.ZP99
	}

	line := charts.NewLine()
	line.SetGlobalOptions(commonGlobalOpts(title, subtitle, "max |Z-score|", false)...)

	n := len(x)
	compositeData := floatSliceToLineData(composite)
	compositeOpts := []charts.SeriesOpts{
		charts.WithLineChartOpts(opts.LineChart{Smooth: opts.Bool(true)}),
		charts.WithLineStyleOpts(opts.LineStyle{Width: 2.5, Color: "#2ca02c"}),
		charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
	}
	compositeOpts = append(compositeOpts, brmBlockMarkAreaOpts(brmBlocks, x)...)

	mkRef := func(val float64) []opts.LineData {
		d := make([]opts.LineData, n)
		for i := range d {
			d[i] = opts.LineData{Value: val}
		}
		return d
	}

	line.SetXAxis(positionLabels(x)).
		AddSeries("Statistic", compositeData, compositeOpts...).
		AddSeries("z=2 (sugg.)", mkRef(z2),
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.4, Color: "#f39c12"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		).
		AddSeries("z=3 (sig.)", mkRef(z3),
			charts.WithLineStyleOpts(opts.LineStyle{Type: "dashed", Width: 1.8, Color: "#e74c3c"}),
			charts.WithItemStyleOpts(opts.ItemStyle{Opacity: opts.Float(0)}),
		)

	return line
}

func statColor(name string) string {
	switch name {
	case "HighSI":
		return "#1f77b4"
	case "LowSI":
		return "#ff7f0e"
	case "DeltaSI", "AFDev":
		return "#2ca02c"
	case "Gstat":
		return "#17becf"
	case "ED4", "ED":
		return "#d62728"
	case "LOD":
		return "#9467bd"
	case "BBLogBF":
		return "#8c564b"
	}
	return "#7f7f7f"
}

func brmBlockMarkAreaOpts(blocks []stats.BRMBlock, x []int64) []charts.SeriesOpts {
	if len(blocks) == 0 || len(x) == 0 {
		return nil
	}

	xLabels := positionLabels(x)
	areas := make([][]opts.MarkAreaData, 0, len(blocks))
	for _, b := range blocks {
		startIdx := sort.Search(len(x), func(i int) bool { return x[i] >= b.Start })
		stopIdx := sort.Search(len(x), func(i int) bool { return x[i] > b.Stop }) - 1
		if startIdx >= len(x) || stopIdx < 0 {
			continue
		}
		if stopIdx < startIdx {
			stopIdx = startIdx
		}
		areas = append(areas, []opts.MarkAreaData{
			{Name: fmt.Sprintf("BRM block %.4f", b.Peak), XAxis: xLabels[startIdx]},
			{XAxis: xLabels[stopIdx]},
		})
	}
	if len(areas) == 0 {
		return nil
	}

	return []charts.SeriesOpts{
		charts.WithMarkAreaData(areas...),
		charts.WithMarkAreaStyleOpts(opts.MarkAreaStyle{
			Label:     &opts.Label{Show: opts.Bool(false)},
			ItemStyle: &opts.ItemStyle{Color: "rgba(243, 156, 18, 0.22)"},
		}),
	}
}

func floatSliceToLineData(vals []float64) []opts.LineData {
	ld := make([]opts.LineData, len(vals))
	for i, v := range vals {
		ld[i] = opts.LineData{Value: v}
	}
	return ld
}

func positionLabels(x []int64) []string {
	labels := make([]string, len(x))
	for i, v := range x {
		labels[i] = fmt.Sprintf("%d", v)
	}
	return labels
}

func writeHTMLPage(page *components.Page, path string) error {
	f, err := os.Create(path)
	if err != nil {
		return fmt.Errorf("create %s: %w", path, err)
	}
	if err := page.Render(f); err != nil {
		_ = f.Close()
		return fmt.Errorf("render %s: %w", path, err)
	}
	if err := f.Close(); err != nil {
		return fmt.Errorf("close %s: %w", err)
	}
	return nil
}
