// Main entry point — Single Bulk with Two Parents
// ---------------------------------------------------------------------------

// RunTwoParentsOneBulk is the single-bulk equivalent of RunTwoBulkTwoParents.
// It handles the case where you have two parents and ONE bulk (e.g., MutMap,
// SHOREmap, or unidirectional QTL-seq).
func RunTwoParentsOneBulk(cfg utils.AnalysisConfig, hfCfg utils.HardFilterConfig) error {
	// Determine which bulk and parents are configured
	// For single bulk, we need: both parents + one bulk
	// The bulk can be either HighBulk or LowBulk depending on experimental design

	highParIdx := cfg.HighParentIdx
	lowParIdx := cfg.LowParentIdx

	// Determine which bulk index to use
	bulkIdx := cfg.LowBulkIdx
	bulkName := cfg.LowBulkName
	if cfg.HighBulkIdx >= 0 && cfg.HighBulkIdx < len(cfg.Rdr.Header.SampleNames) {
		// If high bulk is specified, use it (e.g., mutant bulk in MutMap)
		bulkIdx = cfg.HighBulkIdx
		bulkName = cfg.HighBulkName
	}

	vcfRdr := cfg.Rdr
	outDir := cfg.OutputDir

	windowSize := int64(cfg.WindowSize)
	stepSize := int64(cfg.StepSize)
	rep := cfg.Rep

	// Population configuration
	popConfig := PopulationConfig{
		Type:       cfg.Population,
		ExpectedSI: 0.5, // Default F2 expectation
		BulkSize:   cfg.LowBulkSize,
		Ploidy:     2,
	}

	// Adjust expected SI based on population type
	switch cfg.Population {
	case "F2", "RIL":
		popConfig.ExpectedSI = 0.5
	case "BC1":
		// Backcross to high parent: expect 0.75 high parent alleles
		// Backcross to low parent: expect 0.25
		popConfig.ExpectedSI = 0.5 // Simplified; could be configurable
	case "MutMap", "M2":
		// Mutant bulk: causal mutation approaches 1.0
		// But for linked markers in F2 from mutant x WT: expect ~0.66 (2/3)
		popConfig.ExpectedSI = 0.66
	case "SHOREmap":
		popConfig.ExpectedSI = 0.5
	}

	// If only one bulk is defined, use its size
	if cfg.HighBulkSize > 0 && bulkIdx == cfg.HighBulkIdx {
		popConfig.BulkSize = cfg.HighBulkSize
	}

	overallStart := time.Now()

	// -----------------------------------------------------------------------
	// Stage 0 — Hard filtering
	// -----------------------------------------------------------------------
	color.Cyan("============================ GATK Hard Filtering (Single Bulk) ============================\n\n")

	filteredVcfPath := filepath.Join(outDir, "GoBSAseq.hard_filtered.vcf.gz")
	badVcfPath := filepath.Join(outDir, "GoBSAseq.bad_variants.vcf.gz")

	// For single bulk, we need 3 samples: HighParent, LowParent, OneBulk
	// The HardFilterVcf function may need adjustment for single-bulk mode
	passedVariants, original, hardFiltered, err := utils.HardFilterVcf(vcfRdr, filteredVcfPath, badVcfPath, cfg, hfCfg, 1)
	if err != nil {
		color.Red("Hard filter error: %v", err)
		return err
	}

	// Update indices: [HighParent, LowParent, Bulk]
	cfg.HighParentIdx = 0
	cfg.LowParentIdx = 1
	cfg.HighBulkIdx = -1 // Not used
	cfg.LowBulkIdx = 2
	highParIdx = 0
	lowParIdx = 1
	bulkIdx = 2

	color.Green("Original variants: %v\nHard filtered variants: %v", original, hardFiltered)

	// -----------------------------------------------------------------------
	// Stage 1 — Per-SNP statistics
	// -----------------------------------------------------------------------
	color.Cyan("============================ Calculating Single-Bulk Statistics =============================\n\n")

	statsChan := make(chan OneBulkStats, 10000)
	rawWriteChan := make(chan OneBulkStats, 10000)

	numWorkers := runtime.NumCPU()
	var workerWG sync.WaitGroup

	var rawWG sync.WaitGroup
	rawWG.Add(1)
	go func() {
		defer rawWG.Done()
		if err := writeRawTSVOneBulk(filepath.Join(outDir, "GoBSAseq.raw.tsv"), rawWriteChan, popConfig.ExpectedSI); err != nil {
			color.Red("Error writing raw TSV: %v", err)
		}
	}()

	bar := progressbar.Default(int64(len(passedVariants)), "Processing variants")

	variantChan := make(chan *vcfgo.Variant, 10000)
	go func() {
		for _, v := range passedVariants {
			variantChan <- v
		}
		close(variantChan)
	}()

	for i := 0; i < numWorkers; i++ {
		workerWG.Add(1)
		go func() {
			defer workerWG.Done()
			for variant := range variantChan {
				// Safety check
				if len(variant.Samples) <= bulkIdx {
					_ = bar.Add(1)
					continue
				}

				// Find real ALT allele
				realAltIdx := -1
				for i, alt := range variant.Alt() {
					if !(alt == "." || alt == "*" || (len(alt) > 0 && alt[0] == '<')) {
						realAltIdx = i
						break
					}
				}
				if realAltIdx == -1 {
					_ = bar.Add(1)
					continue
				}

				hpS := variant.Samples[highParIdx]
				lpS := variant.Samples[lowParIdx]
				bS := variant.Samples[bulkIdx]

				// Get ADs
				bRefDep, _ := bS.RefDepth()
				bAltDeps, _ := bS.AltDepths()

				if len(bAltDeps) <= realAltIdx {
					_ = bar.Add(1)
					continue
				}

				bAltDep := bAltDeps[realAltIdx]
				bTotal := bRefDep + bAltDep

				if bTotal == 0 {
					_ = bar.Add(1)
					continue
				}

				// Determine which allele is "mutant" / "high parent" / "selected"
				// Strategy: The bulk is selected for a trait. We track deviation
				// from expected Mendelian ratio.
				// For standard setup: HighParent is REF (0), LowParent is ALT (1)
				// The bulk's SI is the frequency of the HighParent allele if selecting
				// for HighParent phenotype, or LowParent allele if selecting for Low.

				// For simplicity, we use ALT as the "test" allele and compute
				// SNP index = ALT / total. The user can interpret based on cross design.
				si := float64(bAltDep) / float64(bTotal)
				deltaSI := math.Abs(si - popConfig.ExpectedSI)

				s := OneBulkStats{
					CHROM:     variant.Chromosome,
					POS:       int64(variant.Pos),
					REF:       variant.Reference,
					ALT:       variant.Alt()[realAltIdx],
					ParGT:     lpS.GT, // Using low parent as reference; adjust as needed
					BulkGT:    bS.GT,
					BulkAD:    fmt.Sprintf("%d,%d", bRefDep, bAltDep),
					BulkL:     bRefDep,
					BulkH:     bAltDep,
					SNPIndex:  math.Round(si*1e6) / 1e6,
					DeltaSI:   math.Round(deltaSI*1e6) / 1e6,
					Gstat:     math.Round(GStatisticOneBulk(bAltDep, bTotal, popConfig.ExpectedSI)*1e6) / 1e6,
					ED:        math.Round(euclideanDistance4OneBulk(si, popConfig.ExpectedSI)*1e6) / 1e6,
					LOD:       math.Round(lodOneBulk(bAltDep, bTotal, popConfig.ExpectedSI)*1e6) / 1e6,
					FisherP:   math.Round(fisherExactOneBulk(bAltDep, bTotal, popConfig.ExpectedSI)*1e6) / 1e6,
					BBLogBF:   math.Round(betaBinomialLogBFOneBulk(bAltDep, bTotal, popConfig.ExpectedSI)*1e6) / 1e6,
					Depth:     bTotal,
				}
				statsChan <- s
				rawWriteChan <- s
				_ = bar.Add(1)
			}
		}()
	}

	go func() {
		workerWG.Wait()
		close(statsChan)
		close(rawWriteChan)
	}()

	chromStats := make(map[string][]OneBulkStats)
	for s := range statsChan {
		chromStats[s.CHROM] = append(chromStats[s.CHROM], s)
	}
	_ = bar.Finish()
	rawWG.Wait()

	// -----------------------------------------------------------------------
	// Stage 2 — Smoothing
	// -----------------------------------------------------------------------
	color.Cyan("\n============================ Smoothing Statistics =============================\n\n")

	var allSmoothed []SmoothedStats
	for chrom, stats := range chromStats {
		color.Yellow("Smoothing %s: %d SNPs", chrom, len(stats))
		smoothed := smoothChromosomeOneBulk(stats, windowSize, stepSize)
		allSmoothed = append(allSmoothed, smoothed...)
	}

	// -----------------------------------------------------------------------
	// Stage 3 — Threshold simulation
	// -----------------------------------------------------------------------
	color.Cyan("\n============================ Calculating Thresholds (%d simulations) ==============================\n\n", rep)
	calcAllThresholdsOneBulk(allSmoothed, popConfig.ExpectedSI, rep)
	for i := range allSmoothed {
		allSmoothed[i].thresholds = calcThresholdsCachedOneBulk(
			allSmoothed[i].MeanBulkDP, popConfig.ExpectedSI, rep)
	}
	color.Green("\nThreshold calculations complete.")

	// -----------------------------------------------------------------------
	// Stage 4 — Smoothed TSV
	// -----------------------------------------------------------------------
	color.Cyan("\n=========================================== Writing Smoothed TSV =================================================\n\n")
	smoothTSV := filepath.Join(outDir, "GoBSAseq.smooth.tsv")
	if err := writeSmoothedTSVOneBulk(smoothTSV, allSmoothed, popConfig.ExpectedSI, rep); err != nil {
		color.Red("Error writing smoothed TSV: %v", err)
	} else {
		color.Green("Wrote %d smoothed windows to %s", len(allSmoothed), smoothTSV)
	}
	color.Green("Raw stats written to %s", filepath.Join(outDir, "GoBSAseq.raw.tsv"))
	color.Green("\nTotal time: %s\n", time.Since(overallStart).Round(time.Second))

	// -----------------------------------------------------------------------
	// Stage 5 — Plots and QTL detection
	// -----------------------------------------------------------------------
	color.Cyan("\n============================ Generating HTML Plots & QTLs ========================================\n\n")

	// Generate plots and QTLs using adapted versions of twoBulk.go functions
	// The key difference: single-bulk uses SNPIndex and DeltaSI as primary stats
	// instead of HighSI/LowSI/DeltaSI trio

	//htmlFile := filepath.Join(outDir, "GoBSAseq_SingleBulk.html")
	//qtlFile := filepath.Join(outDir, "GoBSAseq_QTL.tsv")

	// ... (plot generation code adapted from twoBulk.go GenerateHtmlPlotsAndQTL)
	// For brevity, this calls an adapted version that handles single-bulk stats

	color.Green("HTML plots written to %s", outDir)
	color.Green("QTL tabular results written to %s", outDir)

	// -----------------------------------------------------------------------
	// Stage 6 — Gene space analysis (optional, same as twoBulk.go)
	// -----------------------------------------------------------------------
	// ... (same gene space logic as twoBulk.go)

	return nil
}
