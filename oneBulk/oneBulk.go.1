func writeRawTSVOneBulk(filename string, statsChan <-chan OneBulkStats, expectedSI float64) error {
	f, err := os.Create(filename)
	if err != nil {
		return err
	}
	defer f.Close()

	w := bufio.NewWriter(f)
	defer w.Flush()

	fmt.Fprintf(w, "CHROM\tPOS\tREF\tALT\tParGT\tBulkGT\tBulkAD\tBulkL\tBulkH\tSNPIndex\tDeltaSI\tExpectedSI\tGstat\tED4\tLOD\tFisherP\tBBLogBF\tDepth\n")
	for s := range statsChan {
		fmt.Fprintf(w, "%s\t%d\t%s\t%s\t%v\t%v\t%s\t%d\t%d\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%d\n",
			s.CHROM, s.POS, s.REF, s.ALT,
			s.ParGT, s.BulkGT, s.BulkAD,
			s.BulkL, s.BulkH,
			s.SNPIndex, s.DeltaSI, expectedSI,
			s.Gstat, s.ED, s.LOD, s.FisherP, s.BBLogBF,
			s.Depth)
	}
	return nil
}

func writeSmoothedTSVOneBulk(filename string, data []SmoothedStats, expectedSI float64, rep int) error {
	f, err := os.Create(filename)
	if err != nil {
		return err
	}
	defer f.Close()

	w := bufio.NewWriter(f)
	defer w.Flush()

	header := "CHROM\tPOS\tSNPIndex\tDeltaSI\tGstat\tED4\tLOD\tBBLogBF\tNumSNPs\tMeanBulkDP" +
		"\tSNPIndex_p99\tSNPIndex_p95\tSNPIndex_m_p99\tSNPIndex_m_p95" +
		"\tDeltaSI_p99\tDeltaSI_p95" +
		"\tGstat_p99\tGstat_p95" +
		"\tED4_p99\tED4_p95" +
		"\tLOD_p99\tLOD_p95" +
		"\tBBLogBF_p99\tBBLogBF_p95"
	fmt.Fprintln(w, header)

	for _, d := range data {
		t := calcThresholdsCachedOneBulk(d.MeanBulkDP, expectedSI, rep)
		row := fmt.Sprintf(
			"%s\t%d\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%.6f\t%d\t%d"+
				"\t%.6f\t%.6f\t%.6f\t%.6f"+
				"\t%.6f\t%.6f"+
				"\t%.6f\t%.6f"+
				"\t%.6f\t%.6f"+
				"\t%.6f\t%.6f"+
				"\t%.6f\t%.6f",
			d.CHROM, d.POS,
			d.SNPIndex, d.DeltaSI, d.Gstat, d.ED, d.LOD, d.BBLogBF,
			d.NumSNPs, d.MeanBulkDP,
			t.SiP99, t.SiP95, t.SiMp99, t.SiMp95,
			t.DsiP99, t.DsiP95,
			t.GsP99, t.GsP95,
			t.EdP99, t.EdP95,
			t.LodP99, t.LodP95,
			t.BbP99, t.BbP95,
		)
		fmt.Fprintln(w, row)
	}
	return nil
}

// ---------------------------------------------------------------------------
// Robust Z-score helpers (reuse from twoBulk.go)
// ---------------------------------------------------------------------------

func robustBackground(vals []float64, trimFrac float64) (median, mad float64) {
	if len(vals) == 0 {
		return 0, 0
	}
	sorted := make([]float64, len(vals))
	copy(sorted, vals)
	sort.Float64s(sorted)

	cutIdx := int(math.Round(float64(len(sorted)) * (1.0 - trimFrac)))
	if cutIdx < 1 {
		cutIdx = 1
	}
	trimmed := sorted[:cutIdx]

	median = quantile(trimmed, 0.5)

	devs := make([]float64, len(trimmed))
	for i, v := range trimmed {
		devs[i] = math.Abs(v - median)
	}
	sort.Float64s(devs)
	mad = quantile(devs, 0.5)
	return median, mad
}

func quantile(sorted []float64, p float64) float64 {
	n := len(sorted)
	if n == 0 {
		return 0
	}
	if p <= 0 {
		return sorted[0]
	}
	if p >= 1 {
		return sorted[n-1]
	}
	pos := p * float64(n-1)
	lo := int(math.Floor(pos))
	hi := int(math.Ceil(pos))
	if lo == hi {
		return sorted[lo]
	}
	frac := pos - float64(lo)
	return sorted[lo]*(1-frac) + sorted[hi]*frac
}

func robustZScore(vals []float64, median, mad float64) []float64 {
	out := make([]float64, len(vals))
	scale := mad * 1.4826
	if scale == 0 {
		return out
	}
	for i, v := range vals {
		out[i] = (v - median) / scale
	}
	return out
}

