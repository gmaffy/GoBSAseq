// ---------------------------------------------------------------------------
// Core Statistics — Single Bulk
// ---------------------------------------------------------------------------

// GStatisticOneBulk computes G-statistic testing deviation from expected ratio.
// Under null: alt count ~ Binomial(n, expectedAltFrac)
func GStatisticOneBulk(altCount, totalCount int, expectedAltFrac float64) float64 {
	if totalCount == 0 || expectedAltFrac <= 0 || expectedAltFrac >= 1 {
		return 0
	}
	obsAlt := float64(altCount) + 0.5
	obsRef := float64(totalCount-altCount) + 0.5
	expAlt := (float64(totalCount) + 1.0) * expectedAltFrac
	expRef := (float64(totalCount) + 1.0) * (1 - expectedAltFrac)

	g := 0.0
	if obsAlt > 0 {
		g += obsAlt * math.Log(obsAlt/expAlt)
	}
	if obsRef > 0 {
		g += obsRef * math.Log(obsRef/expRef)
	}
	return 2 * g
}

// euclideanDistance4OneBulk computes ED^4 for single bulk:
// ED = |SI - expectedSI|, raised to 4th power to amplify signal
func euclideanDistance4OneBulk(si, expectedSI float64) float64 {
	d := si - expectedSI
	return d * d * d * d
}

// lodOneBulk computes LOD score comparing:
// H1: allele freq = observed p vs H0: allele freq = expected p
func lodOneBulk(altCount, totalCount int, expectedP float64) float64 {
	if totalCount == 0 {
		return 0
	}
	n := float64(totalCount)
	k := float64(altCount)

	const eps = 1e-10
	clamp := func(p float64) float64 {
		if p <= 0 {
			return eps
		}
		if p >= 1 {
			return 1 - eps
		}
		return p
	}

	pObs := clamp(k / n)
	pExp := clamp(expectedP)

	logLik := func(k, n, p float64) float64 {
		if n == 0 || k < 0 || k > n {
			return 0
		}
		return k*math.Log(p) + (n-k)*math.Log(1-p)
	}

	logL1 := logLik(k, n, pObs)
	logL0 := logLik(k, n, pExp)
	return (logL1 - logL0) / math.Log(10)
}

// fisherExactOneBulk returns -log10(p) from Fisher's exact test
// testing if observed alt count deviates from expected.
// For computational efficiency, we use a normal approximation with
// continuity correction when n > 20, exact calculation otherwise.
func fisherExactOneBulk(altCount, totalCount int, expectedP float64) float64 {
	if totalCount == 0 {
		return 0
	}
	n := float64(totalCount)
	k := float64(altCount)
	expK := n * expectedP
	variance := n * expectedP * (1 - expectedP)

	if variance == 0 {
		return 0
	}

	// Two-tailed test: |obs - exp| / sqrt(var)
	z := math.Abs(k-expK) / math.Sqrt(variance)
	// Convert to -log10(p): p ≈ 2 * (1 - Φ(|z|))
	p := 2.0 * (1.0 - distuv.UnitNormal.CDF(z))
	if p <= 0 {
		p = 1e-300
	}
	return -math.Log10(p)
}

// betaBinomialLogBFOneBulk compares:
// H1: beta-binomial with empirical mean vs H0: beta-binomial fixed at expected
func betaBinomialLogBFOneBulk(altCount, totalCount int, expectedP float64) float64 {
	if totalCount == 0 {
		return 0
	}
	succ := altCount
	fail := totalCount - altCount

	// H1: empirical estimate (Jeffreys prior)
	alpha1, beta1 := 0.5+float64(succ), 0.5+float64(fail)
	logAlt := logBeta(alpha1, beta1) - logBeta(0.5, 0.5)

	// H0: fixed at expected (Dirac prior at expectedP, approximated by tight beta)
	// Use pseudo-counts centered at expectedP with small variance
	alpha0 := 0.5 + float64(totalCount)*expectedP
	beta0 := 0.5 + float64(totalCount)*(1-expectedP)
	logNull := logBeta(alpha0+float64(succ), beta0+float64(fail)) - logBeta(alpha0, beta0)

	return (logAlt - logNull) / math.Log(10)
}

func logBeta(a, b float64) float64 {
	la, _ := math.Lgamma(a)
	lb, _ := math.Lgamma(b)
	lab, _ := math.Lgamma(a + b)
	return la + lb - lab
}

// ---------------------------------------------------------------------------
// Threshold Simulation — Single Bulk
// ---------------------------------------------------------------------------

func calcThresholdsOneBulk(bulkDP int, expectedSI float64, rep int) Thresholds {
	if bulkDP <= 0 || rep <= 0 || expectedSI <= 0 || expectedSI >= 1 {
		return Thresholds{}
	}

	src := rand.NewSource(time.Now().UnixNano())
	rng := rand.New(src)
	dist := distuv.Binomial{N: float64(bulkDP), P: expectedSI, Src: rng}

	siArr := make([]float64, rep)
	dsiArr := make([]float64, rep)
	gsArr := make([]float64, rep)
	edArr := make([]float64, rep)
	lodArr := make([]float64, rep)
	bbArr := make([]float64, rep)

	for i := 0; i < rep; i++ {
		alt := dist.Rand()
		ref := float64(bulkDP) - alt
		si := math.Round((alt/float64(bulkDP))*1e6) / 1e6
		dsi := math.Abs(si - expectedSI)

		siArr[i] = si
		dsiArr[i] = math.Round(dsi*1e6) / 1e6
		gsArr[i] = math.Round(GStatisticOneBulk(int(alt), bulkDP, expectedSI)*1e6) / 1e6
		edArr[i] = math.Round(euclideanDistance4OneBulk(si, expectedSI)*1e6) / 1e6
		lodArr[i] = math.Round(lodOneBulk(int(alt), bulkDP, expectedSI)*1e6) / 1e6
		bbArr[i] = math.Round(betaBinomialLogBFOneBulk(int(alt), bulkDP, expectedSI)*1e6) / 1e6
	}

	sort.Float64s(siArr)
	sort.Float64s(dsiArr)
	sort.Float64s(gsArr)
	sort.Float64s(edArr)
	sort.Float64s(lodArr)
	sort.Float64s(bbArr)

	return Thresholds{
		SiP99:  math.Round(stat.Quantile(0.995, stat.Empirical, siArr, nil)*1e6) / 1e6,
		SiP95:  math.Round(stat.Quantile(0.95, stat.Empirical, siArr, nil)*1e6) / 1e6,
		SiMp99: math.Round(stat.Quantile(0.005, stat.Empirical, siArr, nil)*1e6) / 1e6,
		SiMp95: math.Round(stat.Quantile(0.05, stat.Empirical, siArr, nil)*1e6) / 1e6,

		DsiP99: math.Round(stat.Quantile(0.995, stat.Empirical, dsiArr, nil)*1e6) / 1e6,
		DsiP95: math.Round(stat.Quantile(0.95, stat.Empirical, dsiArr, nil)*1e6) / 1e6,

		GsP99: math.Round(stat.Quantile(0.995, stat.Empirical, gsArr, nil)*1e6) / 1e6,
		GsP95: math.Round(stat.Quantile(0.95, stat.Empirical, gsArr, nil)*1e6) / 1e6,

		EdP99: math.Round(stat.Quantile(0.995, stat.Empirical, edArr, nil)*1e6) / 1e6,
		EdP95: math.Round(stat.Quantile(0.95, stat.Empirical, edArr, nil)*1e6) / 1e6,

		LodP99: math.Round(stat.Quantile(0.995, stat.Empirical, lodArr, nil)*1e6) / 1e6,
		LodP95: math.Round(stat.Quantile(0.95, stat.Empirical, lodArr, nil)*1e6) / 1e6,

		BbP99: math.Round(stat.Quantile(0.995, stat.Empirical, bbArr, nil)*1e6) / 1e6,
		BbP95: math.Round(stat.Quantile(0.95, stat.Empirical, bbArr, nil)*1e6) / 1e6,
	}
}

func calcThresholdsCachedOneBulk(bulkDP int, expectedSI float64, rep int) Thresholds {
	key := fmt.Sprintf("1b_%d_%.6f_%d", bulkDP, expectedSI, rep)
	if v, ok := thresholdCache.Load(key); ok {
		return v.(Thresholds)
	}
	t := calcThresholdsOneBulk(bulkDP, expectedSI, rep)
	actual, _ := thresholdCache.LoadOrStore(key, t)
	return actual.(Thresholds)
}

func calcAllThresholdsOneBulk(allSmoothed []SmoothedStats, expectedSI float64, rep int) {
	seen := make(map[int]bool)
	for _, sm := range allSmoothed {
		if sm.MeanBulkDP > 0 {
			seen[sm.MeanBulkDP] = true
		}
	}

	deps := make([]int, 0, len(seen))
	for d := range seen {
		deps = append(deps, d)
	}
	if len(deps) == 0 {
		return
	}

	bar := progressbar.NewOptions(len(deps),
		progressbar.OptionSetDescription("Computing single-bulk thresholds"),
		progressbar.OptionSetWidth(40),
		progressbar.OptionShowCount(),
		progressbar.OptionSetTheme(progressbar.Theme{
			Saucer:        "=",
			SaucerHead:    ">",
			SaucerPadding: " ",
			BarStart:      "[",
			BarEnd:        "]",
		}),
	)

	depChan := make(chan int, len(deps))
	for _, d := range deps {
		depChan <- d
	}
	close(depChan)

	var wg sync.WaitGroup
	for w := 0; w < runtime.NumCPU(); w++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for dp := range depChan {
				calcThresholdsCachedOneBulk(dp, expectedSI, rep)
				_ = bar.Add(1)
			}
		}()
	}
	wg.Wait()
	fmt.Println()
}

// ---------------------------------------------------------------------------
// Smoothing — Single Bulk
// ---------------------------------------------------------------------------

func tricubeWeight(d, D float64) float64 {
	if D <= 0 || d >= D {
		return 0
	}
	x := 1 - math.Pow(d/D, 3)
	return x * x * x
}

func smoothChromosomeOneBulk(stats []OneBulkStats, windowSize, step int64) []SmoothedStats {
	if len(stats) == 0 || windowSize <= 0 || step <= 0 {
		return nil
	}

	sort.Slice(stats, func(i, j int) bool { return stats[i].POS < stats[j].POS })

	var smoothed []SmoothedStats
	chrom := stats[0].CHROM
	minPos := stats[0].POS
	maxPos := stats[len(stats)-1].POS

	for center := minPos; center <= maxPos; center += step {
		windowStart := center - windowSize/2
		windowEnd := center + windowSize/2

		var (
			sumSI, sumDeltaSI, sumWeightStat float64
			sumGstat, sumWeightGs            float64
			sumLOD, sumWeightLod             float64
			sumBBLogBF, sumWeightBB          float64
			sumED, sumWeightED               float64
			sumDP                            float64
			nSNPs                            int
		)

		for _, s := range stats {
			if s.POS < windowStart || s.POS > windowEnd {
				continue
			}
			nSNPs++

			d := math.Abs(float64(s.POS - center))
			w := tricubeWeight(d, float64(windowSize)/2)
			depthWeight := math.Sqrt(float64(s.Depth))
			wStat := w * depthWeight

			sumSI += s.SNPIndex * wStat
			sumDeltaSI += s.DeltaSI * wStat
			sumWeightStat += wStat
			sumGstat += s.Gstat * wStat
			sumWeightGs += wStat
			sumLOD += s.LOD * wStat
			sumWeightLod += wStat
			sumBBLogBF += s.BBLogBF * wStat
			sumWeightBB += wStat
			sumED += s.ED * wStat
			sumWeightED += wStat
			sumDP += float64(s.Depth)
		}

		if nSNPs < minSNPsPerWindow {
			continue
		}

		sm := SmoothedStats{
			CHROM:      chrom,
			POS:        center,
			NumSNPs:    nSNPs,
			MeanBulkDP: int(sumDP / float64(nSNPs)),
		}
		if sumWeightStat > 0 {
			sm.SNPIndex = sumSI / sumWeightStat
			sm.DeltaSI = sumDeltaSI / sumWeightStat
		}
		if sumWeightGs > 0 {
			sm.Gstat = sumGstat / sumWeightGs
		}
		if sumWeightLod > 0 {
			sm.LOD = sumLOD / sumWeightLod
		}
		if sumWeightBB > 0 {
			sm.BBLogBF = sumBBLogBF / sumWeightBB
		}
		if sumWeightED > 0 {
			sm.ED = sumED / sumWeightED
		}

		smoothed = append(smoothed, sm)
	}

	return smoothed
}

