// ExpectedRatio defines the Mendelian expectation based on population type
type ExpectedRatio struct {
	// For F2: 0.5, for BC1: 0.5 (if backcrossing to recessive parent) or 0.25/0.75
	// For MutMap (mutant bulk from M2/F2 of mutant x WT): 1.0 at causal locus
	// For SHOREmap: depends on crossing scheme
	SNPIndex float64
	// For G-statistic: expected counts under null
	ExpAltFrac float64
}

// PopulationConfig holds population-specific parameters
type PopulationConfig struct {
	Type       string  // "F2", "BC1", "MutMap", "SHOREmap", "RIL"
	ExpectedSI float64 // Expected SNP index under null (no linkage)
	BulkSize   int     // Number of individuals in bulk
	Ploidy     int     // Effective ploidy (2 for diploid F2, 1 if homozygous)
}

// OneBulkStats holds per-SNP statistics for single-bulk analysis
type OneBulkStats struct {
	CHROM     string
	POS       int64
	REF       string
	ALT       string
	ParGT     []int   // Parent genotype (for reference)
	BulkGT    []int
	BulkAD    string

	BulkL int // Count of "low" allele (parental reference)
	BulkH int // Count of "high" allele (parental alternate/mutant)

	SNPIndex float64 // ALT / total (or mutant allele / total)
	DeltaSI  float64 // |SNPIndex - ExpectedSI| — deviation from expectation

	Gstat   float64 // G-test vs. expected ratio
	ED      float64 // |SNPIndex - ExpectedSI|^4 (amplified deviation)
	LOD     float64 // Log-likelihood ratio
	FisherP float64 // Fisher's exact test p-value
	BBLogBF float64 // Beta-binomial vs. expected

	Depth int
}

