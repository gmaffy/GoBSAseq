type QTLRecord struct {
	Chrom     string
	Start     int64
	Stop      int64
	PeakPos   int64
	PeakVal   float64
	Stat      string
	Threshold string
	NQTLs     int
}

type DirectQTLRecord struct {
	Chrom      string
	Start      int64
	Stop       int64
	PeakPos    int64
	ZPeak      float64
	Statistics string
	Threshold  string
	NQTLs      int
}

type MergedQTL struct {
	Chrom string
	Start int64
	Stop  int64
	ZPeak float64
	BRMPeak float64
	BRMThreshold float64
	Source string
}


func (m MergedQTL) geneSpaceRegion() (string, int, int) {
	return m.Chrom, int(m.Start), int(m.Stop)
}



func DetectQTLsWithMCDirect(smoothed []SmoothedStats, thresh []Thresholds, bsaType string, cfg *utils.AnalysisConfig) error {
	color.Cyan("--> Running direct single-statistic Monte Carlo evaluations...")

	if len(smoothed) == 0 {
		return nil
	}
	if len(thresh) != len(smoothed) {
		return fmt.Errorf("smoothed and threshold slices must have the same length")
	}

	_, _, hasBothBulks, hasOneBulk := BulkFlags(bsaType)

	var records []DirectQTLRecord

	// Helper: condense a contiguous significant run into one DirectQTLRecord.
	flushDirectRun := func(run []SmoothedStats, statsNames []string, tierLabel string) {
		if len(run) == 0 {
			return
		}
		var peakPos int64
		var maxPeak float64
		maxAbs := -1.0

		for _, s := range run {
			if math.Abs(s.CompositeZ) > maxAbs {
				maxAbs = math.Abs(s.CompositeZ)
				peakPos = s.POS
				maxPeak = s.CompositeZ
			}
		}

		records = append(records, DirectQTLRecord{
			Chrom:      run[0].CHROM,
			Start:      run[0].POS,
			Stop:       run[len(run)-1].POS,
			PeakPos:    peakPos,
			ZPeak:      maxPeak,
			Statistics: fmt.Sprintf("%v", statsNames),
			Threshold:  tierLabel,
		})
	}


	type runState struct {
		variants   []SmoothedStats
		names      []string
		tier       string
		gapCounter int
	}
	const directMaxGaps = 3
	const directMinVariants = 5
	var active *runState

	flush := func() {
		if active != nil && len(active.variants) >= directMinVariants {
			flushDirectRun(active.variants, active.names, active.tier)
		}
		active = nil
	}

	for i, s := range smoothed {
		t := thresh[i]
		var crossedP99 []string
		var crossedP95 []string

		if hasBothBulks {
			tb := t.TwoBulk
			// P99 evaluators — signed bounds for signed statistics.
			if s.SmDeltaSI >= tb.DeltaSIP99 || s.SmDeltaSI <= tb.DeltaSIMp99 {
				crossedP99 = append(crossedP99, "DeltaSI")
			}
			if s.SmGstat >= tb.GstatP99 {
				crossedP99 = append(crossedP99, "Gstat")
			}
			if s.SmLOD >= tb.LODP99 {
				crossedP99 = append(crossedP99, "LOD")
			}
			if s.SmBBLogBF >= tb.BBLogBFP99 {
				crossedP99 = append(crossedP99, "BBLogBF")
			}
			// P95 evaluators.
			if s.SmDeltaSI >= tb.DeltaSIP95 || s.SmDeltaSI <= tb.DeltaSIMp95 {
				crossedP95 = append(crossedP95, "DeltaSI")
			}
			if s.SmGstat >= tb.GstatP95 {
				crossedP95 = append(crossedP95, "Gstat")
			}
			if s.SmLOD >= tb.LODP95 {
				crossedP95 = append(crossedP95, "LOD")
			}
			if s.SmBBLogBF >= tb.BBLogBFP95 {
				crossedP95 = append(crossedP95, "BBLogBF")
			}
		}


		if hasOneBulk {
			ob := t.OneBulk
			// P99 evaluators.
			if s.SmAFDev >= ob.AFDevP99 || s.SmAFDev <= ob.AFDevMp99 {
				crossedP99 = append(crossedP99, "AFDev")
			}
			if s.SmOneBulkG >= ob.OneBulkGstatP99 {
				crossedP99 = append(crossedP99, "Gstat")
			}
			if s.SmOneBulkLOD >= ob.OneBulkLODP99 {
				crossedP99 = append(crossedP99, "LOD")
			}
			if s.SmOneBulkBBLogBF >= ob.OneBulkBBLogBFP99 {
				crossedP99 = append(crossedP99, "BBLogBF")
			}
			// P95 evaluators.
			if s.SmAFDev >= ob.AFDevP95 || s.SmAFDev <= ob.AFDevMp95 {
				crossedP95 = append(crossedP95, "AFDev")
			}
			if s.SmOneBulkG >= ob.OneBulkGstatP95 {
				crossedP95 = append(crossedP95, "Gstat")
			}
			if s.SmOneBulkLOD >= ob.OneBulkLODP95 {
				crossedP95 = append(crossedP95, "LOD")
			}
			if s.SmOneBulkBBLogBF >= ob.OneBulkBBLogBFP95 {
				crossedP95 = append(crossedP95, "BBLogBF")
			}
		}


		var thisTier string
		var theseNames []string
		switch {
		case len(crossedP99) > 0:
			thisTier = "P99"
			theseNames = crossedP99
		case len(crossedP95) > 0:
			thisTier = "P95"
			theseNames = crossedP95
		}


		chromBreak := i == len(smoothed)-1 || smoothed[i+1].CHROM != s.CHROM

		if thisTier == "" {

			if active != nil && active.gapCounter < directMaxGaps {
				active.variants = append(active.variants, s)
				active.gapCounter++
			} else {
				flush()
			}
		} else {
			// Significant variant.
			if active != nil && active.tier != thisTier {
				// Tier changed — close the previous run before starting a new one.
				flush()
			}
			if active == nil {
				active = &runState{tier: thisTier}
			}
			active.variants = append(active.variants, s)
			active.gapCounter = 0
			// Accumulate statistic names (deduplicated by the receiver).
			active.names = append(active.names, theseNames...)
		}

		if chromBreak {
			flush()
		}
	}
	// Flush any run still open at the very end of the slice.
	flush()

	// ── Per-chromosome filtering ──────────────────────────────────────────────
	// Group records by chromosome and threshold tier (P99 takes precedence over
	// P95, mirroring the composite hierarchy).  Within the winning tier, retain
	// only the run with the highest |ZPeak| and store the pool size in NQTLs.
	type chromGroup struct {
		p99 []DirectQTLRecord
		p95 []DirectQTLRecord
	}
	groups := make(map[string]*chromGroup)
	var chromOrder []string
	for _, r := range records {
		if _, ok := groups[r.Chrom]; !ok {
			groups[r.Chrom] = &chromGroup{}
			chromOrder = append(chromOrder, r.Chrom)
		}
		if r.Threshold == "P99" {
			groups[r.Chrom].p99 = append(groups[r.Chrom].p99, r)
		} else {
			groups[r.Chrom].p95 = append(groups[r.Chrom].p95, r)
		}
	}

	var finalRecords []DirectQTLRecord
	for _, chrom := range chromOrder {
		g := groups[chrom]
		// Use the highest available tier; fall through to P95 only when no P99
		// runs exist on this chromosome.
		pool := g.p99
		if len(pool) == 0 {
			pool = g.p95
		}
		if len(pool) == 0 {
			continue
		}

		// Merge overlapping or directly adjacent runs on the same chromosome so
		// distinct QTL regions are counted once even if the same peak is split
		// into multiple threshold-crossing runs.
		sort.Slice(pool, func(i, j int) bool {
			if pool[i].Start == pool[j].Start {
				return pool[i].Stop < pool[j].Stop
			}
			return pool[i].Start < pool[j].Start
		})

		mergedPool := make([]DirectQTLRecord, 0, len(pool))
		current := pool[0]
		for _, r := range pool[1:] {
			if r.Start <= current.Stop+1 {
				if r.Stop > current.Stop {
					current.Stop = r.Stop
				}
				if math.Abs(r.ZPeak) > math.Abs(current.ZPeak) {
					current.ZPeak = r.ZPeak
					current.PeakPos = r.PeakPos
				}
				continue
			}
			mergedPool = append(mergedPool, current)
			current = r
		}
		mergedPool = append(mergedPool, current)

		best := mergedPool[0]
		for _, r := range mergedPool[1:] {
			if math.Abs(r.ZPeak) > math.Abs(best.ZPeak) {
				best = r
			}
		}
		best.NQTLs = len(mergedPool)
		finalRecords = append(finalRecords, best)
	}

	// FIX 4: create the output directory before attempting to open the file.
	outDir := filepath.Join(cfg.OutputDir, "qtls")
	if err := os.MkdirAll(outDir, 0775); err != nil {
		return fmt.Errorf("DetectQTLsWithMCDirect: mkdir %s: %w", outDir, err)
	}
	outPath := filepath.Join(outDir, fmt.Sprintf("GoBSAseq.%s.individual_stats_qtls.tsv", bsaType))

	f, err := os.Create(outPath)
	if err != nil {
		return fmt.Errorf("DetectQTLsWithMCDirect: create %s: %w", outPath, err)
	}
	defer f.Close()

	fmt.Fprintln(f, "CHROM\tSTART\tSTOP\tPEAK_POS\tZPEAK\tSTATISTICS\tTHRESHOLD\tN_QTLS")
	for _, r := range finalRecords {
		fmt.Fprintf(f, "%s\t%d\t%d\t%d\t%.6f\t%s\t%s\t%d\n",
			r.Chrom, r.Start, r.Stop, r.PeakPos, r.ZPeak, r.Statistics, r.Threshold, r.NQTLs)
	}

	color.Green("    [OK] Direct single-statistic analysis complete. Written to: %s", outPath)
	return nil
}

// DetectQTLs scans for regions where |CompositeZ| or |MaxAbsZ| exceeds the
// empirical MC threshold using a four-tier fallback hierarchy per chromosome:
//
//  1. CompositeZ  ≥ P99
//  2. CompositeZ  ≥ P95
//  3. MaxAbsZ     ≥ P99
//  4. MaxAbsZ     ≥ P95
//
// Only the highest tier with at least one hit on a chromosome is reported.
// Per chromosome, only the single run with the highest |PeakVal| is retained.
// N_QTLS records how many runs existed above the selected tier.
//
// CompositeZ = Σ Zᵢ / √k  (Stouffer, k=3: ΔSI, G-stat, LOD for two-bulk;
// AFDev, OneBulkG, OneBulkLOD for one-bulk).
func DetectQTLs(smoothed []SmoothedStats, thresh []Thresholds, bsaType string, cfg *utils.AnalysisConfig) ([]QTLRecord, error) {
	color.Cyan("--> Detecting QTLs via hierarchical CompositeZ / MaxAbsZ tracks...")

	if len(smoothed) == 0 {
		return nil, nil
	}
	if len(thresh) != len(smoothed) {
		return nil, fmt.Errorf("smoothed and threshold slices must have the same length")
	}

	// Group variants by chromosome, preserving input order.
	chrMap := make(map[string][]SmoothedStats)
	chrThreshMap := make(map[string][]Thresholds)
	var chroms []string
	for i, s := range smoothed {
		if _, ok := chrMap[s.CHROM]; !ok {
			chroms = append(chroms, s.CHROM)
		}
		chrMap[s.CHROM] = append(chrMap[s.CHROM], s)
		chrThreshMap[s.CHROM] = append(chrThreshMap[s.CHROM], thresh[i])
	}
	sort.Strings(chroms)

	var allQTLs []QTLRecord

	for _, chrom := range chroms {
		variants := chrMap[chrom]
		chromThresholds := chrThreshMap[chrom]
		if len(variants) == 0 {
			continue
		}

		chrQTLs, calledStat, calledThresh := selectChromQTLPool(variants, chromThresholds)

		if len(chrQTLs) == 0 {
			continue
		}

		// Retain only the single run with the highest absolute peak or valley
		// magnitude on the chromosome; record the full pool size in N_QTLS.
		best := selectBestQTL(chrQTLs)
		best.Stat = calledStat
		best.Threshold = calledThresh
		best.NQTLs = len(chrQTLs)
		allQTLs = append(allQTLs, best)
	}

	// Write output TSV.
	outDir := filepath.Join(cfg.OutputDir, "qtls")
	if err := os.MkdirAll(outDir, 0775); err != nil {
		return nil, fmt.Errorf("DetectQTLs: mkdir %s: %w", outDir, err)
	}
	outPath := filepath.Join(outDir, fmt.Sprintf("GoBSAseq.%s.qtls.tsv", bsaType))
	f, err := os.Create(outPath)
	if err != nil {
		return nil, fmt.Errorf("DetectQTLs: create %s: %w", outPath, err)
	}
	defer f.Close()

	fmt.Fprintln(f, "CHROM\tSTART\tSTOP\tPEAK_POS\tPEAK_VAL\tSTAT\tTHRESHOLD\tN_QTLS")
	for _, q := range allQTLs {
		fmt.Fprintf(f, "%s\t%d\t%d\t%d\t%.6f\t%s\t%s\t%d\n",
			q.Chrom, q.Start, q.Stop, q.PeakPos, q.PeakVal, q.Stat, q.Threshold, q.NQTLs)
	}

	color.Green("    [OK] Hierarchical QTL analysis completed. Written to: %s", outPath)
	return allQTLs, nil
}

func findZSegments(variants []SmoothedStats, thresholds []Thresholds, useComposite bool, cutoffFn func(Thresholds) float64) []QTLRecord {
	var records []QTLRecord
	var currentRun []SmoothedStats

	const maxGaps = 3
	const minVariants = 5
	gapCounter := 0

	appendRun := func() {
		if len(currentRun) < minVariants {
			currentRun = nil
			gapCounter = 0
			return
		}

		peakPos, peakVal := peakPosition(currentRun, useComposite)
		records = append(records, QTLRecord{
			Chrom:   currentRun[0].CHROM,
			Start:   currentRun[0].POS,
			Stop:    currentRun[len(currentRun)-1].POS,
			PeakPos: peakPos,
			PeakVal: peakVal,
		})
		currentRun = nil
		gapCounter = 0
	}

	for i, v := range variants {
		score := v.MaxAbsZ
		if useComposite {
			score = v.CompositeZ
		}

		if score >= cutoffFn(thresholds[i]) {
			currentRun = append(currentRun, v)
			gapCounter = 0
		} else if len(currentRun) > 0 {
			if gapCounter < maxGaps {
				currentRun = append(currentRun, v)
				gapCounter++
			} else {
				appendRun()
			}
		}
	}
	appendRun()

	return records
}

func peakPosition(variants []SmoothedStats, useComposite bool) (int64, float64) {
	var peakPos int64
	var peakVal float64
	maxAbs := -1.0
	for _, v := range variants {
		val := v.MaxAbsZ
		if useComposite {
			val = v.CompositeZ
		}
		if math.Abs(val) > maxAbs {
			maxAbs = math.Abs(val)
			peakVal = val
			peakPos = v.POS
		}
	}
	return peakPos, peakVal
}

func selectChromQTLPool(variants []SmoothedStats, thresholds []Thresholds) ([]QTLRecord, string, string) {
	// When a chromosome has any P99-significant run, lower-tier P95 regions are
	// ignored entirely so the final count and representative interval reflect the
	// strongest tier only.
	if chrQTLs := findZSegments(variants, thresholds, true, func(t Thresholds) float64 { return t.Z.CompositeZP99 }); len(chrQTLs) > 0 {
		for i := range chrQTLs {
			chrQTLs[i].NQTLs = len(chrQTLs)
		}
		return chrQTLs, "Stouffer", "P99"
	}
	if chrQTLs := findZSegments(variants, thresholds, true, func(t Thresholds) float64 { return t.Z.CompositeZP95 }); len(chrQTLs) > 0 {
		for i := range chrQTLs {
			chrQTLs[i].NQTLs = len(chrQTLs)
		}
		return chrQTLs, "Stouffer", "P95"
	}
	if chrQTLs := findZSegments(variants, thresholds, false, func(t Thresholds) float64 { return t.Z.ZP99 }); len(chrQTLs) > 0 {
		for i := range chrQTLs {
			chrQTLs[i].NQTLs = len(chrQTLs)
		}
		return chrQTLs, "MaxAbsZ", "P99"
	}
	if chrQTLs := findZSegments(variants, thresholds, false, func(t Thresholds) float64 { return t.Z.ZP95 }); len(chrQTLs) > 0 {
		for i := range chrQTLs {
			chrQTLs[i].NQTLs = len(chrQTLs)
		}
		return chrQTLs, "MaxAbsZ", "P95"
	}
	return nil, "", ""
}

func selectBestQTL(records []QTLRecord) QTLRecord {
	if len(records) == 0 {
		return QTLRecord{}
	}
	best := records[0]
	for _, q := range records[1:] {
		if math.Abs(q.PeakVal) > math.Abs(best.PeakVal) {
			best = q
		}
	}
	return best
}

// ── Merging ───────────────────────────────────────────────────────────────────

// MergeQTLsAndBRM combines QTLRecord and BRMBlock results into a single
// []MergedQTL, unions overlapping / same-chromosome intervals, and writes a
// merged TSV.
//
// Merging rules (per chromosome):
//   - Intervals from both sources on the same chromosome are unioned
//     (Start = min, Stop = max) and labelled "ZScore+BRM".
//   - Intervals present in only one source keep their source label.
//   - Multiple BRM blocks on the same chromosome are first reduced to their
//     bounding interval (widest span, highest |peak|) before merging with the
//     Z-score QTL.  This mirrors the legacy behaviour where only the most
//     extreme block was forwarded to gene space analysis.
func MergeQTLsAndBRM(cfg utils.AnalysisConfig, bsaType string, qtls []QTLRecord, blocks []BRMBlock) ([]MergedQTL, error) {

	nan := math.NaN()

	// Index QTL records by chromosome.
	qtlByChrom := make(map[string]QTLRecord, len(qtls))
	for _, q := range qtls {
		qtlByChrom[q.Chrom] = q
	}

	// Reduce BRM blocks to one representative per chromosome:
	// widest bounding interval, highest |peak| block retained.
	type brmSummary struct {
		start, stop int64
		peak        float64
		threshold   float64
	}
	brmByChrom := make(map[string]brmSummary)
	for _, b := range blocks {
		prev, exists := brmByChrom[b.Chrom]
		if !exists {
			brmByChrom[b.Chrom] = brmSummary{b.Start, b.Stop, b.Peak, b.Threshold}
			continue
		}
		s := prev
		if b.Start < s.start {
			s.start = b.Start
		}
		if b.Stop > s.stop {
			s.stop = b.Stop
		}
		if math.Abs(b.Peak) > math.Abs(s.peak) {
			s.peak = b.Peak
			s.threshold = b.Threshold
		}
		brmByChrom[b.Chrom] = s
	}

	// Build the union set of chromosomes.
	chromSet := make(map[string]struct{})
	for c := range qtlByChrom {
		chromSet[c] = struct{}{}
	}
	for c := range brmByChrom {
		chromSet[c] = struct{}{}
	}
	chroms := make([]string, 0, len(chromSet))
	for c := range chromSet {
		chroms = append(chroms, c)
	}
	sort.Strings(chroms)

	var merged []MergedQTL
	for _, chrom := range chroms {
		q, hasQ := qtlByChrom[chrom]
		b, hasB := brmByChrom[chrom]

		m := MergedQTL{
			Chrom:        chrom,
			ZPeak:        nan,
			BRMPeak:      nan,
			BRMThreshold: nan,
		}

		switch {
		case hasQ && hasB:
			// Union the two intervals.
			m.Start = minI64(q.Start, b.start)
			m.Stop = maxI64(q.Stop, b.stop)
			m.ZPeak = q.PeakVal
			m.BRMPeak = b.peak
			m.BRMThreshold = b.threshold
			m.Source = "ZScore+BRM"

		case hasQ:
			m.Start = q.Start
			m.Stop = q.Stop
			// FIX 5: was q.Peak (non-existent field); correct field is q.PeakVal.
			m.ZPeak = q.PeakVal
			m.Source = "ZScore"

		case hasB:
			m.Start = b.start
			m.Stop = b.stop
			m.BRMPeak = b.peak
			m.BRMThreshold = b.threshold
			m.Source = "BRM"
		}

		merged = append(merged, m)
	}

	// ── write merged TSV ─────────────────────────────────────────────────────

	outDir := filepath.Join(cfg.OutputDir, "qtls")
	if err := os.MkdirAll(outDir, 0775); err != nil {
		return nil, fmt.Errorf("MergeQTLsAndBRM: mkdir: %w", err)
	}
	outPath := filepath.Join(outDir, fmt.Sprintf("GoBSAseq.%s.merged_qtls.tsv", bsaType))

	f, err := os.Create(outPath)
	if err != nil {
		return nil, fmt.Errorf("MergeQTLsAndBRM: create %s: %w", outPath, err)
	}
	defer f.Close()

	fmt.Fprintln(f, "CHROM\tSTART\tSTOP\tSOURCE\tZ_PEAK\tBRM_PEAK\tBRM_THRESHOLD")
	for _, m := range merged {
		fmt.Fprintf(f, "%s\t%d\t%d\t%s\t%s\t%s\t%s\n",
			m.Chrom, m.Start, m.Stop, m.Source,
			nanOrFloat(m.ZPeak),
			nanOrFloat(m.BRMPeak),
			nanOrFloat(m.BRMThreshold),
		)
	}

	color.Green("Merged QTL+BRM intervals written to %s (%d intervals)", outPath, len(merged))
	return merged, nil
}

// ── helpers ───────────────────────────────────────────────────────────────────

func minI64(a, b int64) int64 {
	if a < b {
		return a
	}
	return b
}

func maxI64(a, b int64) int64 {
	if a > b {
		return a
	}
	return b
}

// nanOrFloat formats v as "NA" when it is NaN, otherwise as %.6f.
func nanOrFloat(v float64) string {
	if math.IsNaN(v) {
		return "NA"
	}
	return fmt.Sprintf("%.6f", v)
}
