package stats

// threshold.go — permutation-derived significance thresholds for GoBSAseq
//
// ── REQUIRED PATCH TO smoothing.go ───────────────────────────────────────────
// Add one field to SmoothedStats so each window carries its thresholds:
//
//   type SmoothedStats struct {
//       ...existing fields...
//
//       // Per-window significance thresholds (set by AddThresholds in threshold.go).
//       Thresholds Thresholds
//   }
//
// ─────────────────────────────────────────────────────────────────────────────
//
// Three threshold families are handled here:
//
//  1. TWO-BULK (DeltaSI, HighSI, LowSI, Gstat, ED4, LOD, BBLogBF)
//     Simulated by drawing binomial(n=depth, p=smoothedAF) allele counts for
//     both bulks, computing each statistic, then reading off empirical quantiles.
//     Identical in principle to the calcThresholds function in twoBulk.go, but
//     adapted to the stats package's SmoothedStats type and extended to cover
//     the one-bulk statistics.
//
//  2. ONE-BULK (AFDev, OneBulkGstat, OneBulkLOD, OneBulkBBLogBF)
//     Simulated by drawing a single binomial(n=depth, p=p0) allele count and
//     computing the one-bulk statistics against the null allele frequency p0.
//     p0 is the expected high-allele frequency under the null (e.g. 0.5 for F2).
//
//  3. ROBUST Z-SCORES AND COMPOSITE Z (ZDeltaSI, ZGstat, …, CompositeZ)
//     These are already on a standard-normal scale by construction.  Thresholds
//     are therefore analytical normal quantiles — no simulation is needed.
//     The composite Z threshold accounts for the number of contributing
//     statistics k via the Stouffer factor 1/√k.
//
// All simulation results are cached in sync.Maps so that identical (depth, AF,
// rep) combinations are computed only once across all windows.

import (
	"fmt"
	"math"
	"math/rand"
	"runtime"
	"sort"
	"sync"
	"time"

	"github.com/fatih/color"
	"github.com/gmaffy/GoBSAseq/utils"
	"github.com/schollz/progressbar/v3"
	"gonum.org/v1/gonum/stat"
	"gonum.org/v1/gonum/stat/distuv"
)

// ---------------------------------------------------------------------------
// Threshold structs
// ---------------------------------------------------------------------------

// TwoBulkThresholds holds the permutation-derived significance levels for
// every two-bulk statistic at a given depth / allele-frequency combination.
type TwoBulkThresholds struct {
	// HighSI
	HighSIP99  float64
	HighSIP95  float64
	HighSIMp99 float64 // lower tail (valley)
	HighSIMp95 float64

	// LowSI
	LowSIP99  float64
	LowSIP95  float64
	LowSIMp99 float64
	LowSIMp95 float64

	// DeltaSI
	DeltaSIP99  float64
	DeltaSIP95  float64
	DeltaSIMp99 float64
	DeltaSIMp95 float64

	// Gstat (upper tail only — statistic is non-negative)
	GstatP99 float64
	GstatP95 float64

	// ED4 (upper tail only — statistic is non-negative)
	ED4P99 float64
	ED4P95 float64

	// LOD (upper tail only — statistic is non-negative)
	LODP99 float64
	LODP95 float64

	// BBLogBF (upper tail only — positive BF = evidence for difference)
	BBLogBFP99 float64
	BBLogBFP95 float64
}

// OneBulkThresholds holds the permutation-derived significance levels for
// every one-bulk statistic at a given depth / p0 combination.
type OneBulkThresholds struct {
	// AFDev: signed, so both tails are meaningful.
	AFDevP99  float64 // upper tail
	AFDevP95  float64
	AFDevMp99 float64 // lower tail
	AFDevMp95 float64

	// Unsigned statistics — upper tail only.
	OneBulkGstatP99   float64
	OneBulkGstatP95   float64
	OneBulkLODP99     float64
	OneBulkLODP95     float64
	OneBulkBBLogBFP99 float64
	OneBulkBBLogBFP95 float64
}

// ZThresholds holds analytical standard-normal thresholds for the robust
// Z-scores and the Stouffer composite Z.  These are derived from the normal
// distribution — no simulation is required.
type ZThresholds struct {
	// Individual Z-scores: ±zSig (~p99) and ±zSugg (~p95).
	ZP99 float64 // +zSig  ≈ +3.0
	ZP95 float64 // +zSugg ≈ +2.0
	ZN99 float64 // −zSig  ≈ −3.0
	ZN95 float64 // −zSugg ≈ −2.0

	// Composite Stouffer Z: same thresholds, adjusted for the number of
	// contributing statistics k so the per-window value is comparable.
	// Under the global null all Z_i ~ N(0,1) → CompositeZ ~ N(0,1), so the
	// threshold is simply ±zSig / ±zSugg regardless of k.  We store k as
	// a diagnostic field.
	CompositeZP99 float64
	CompositeZP95 float64
	CompositeZN99 float64
	CompositeZN95 float64
	NumStats      int // k used in Stouffer formula
}

// Thresholds bundles all three families for one SmoothedStats window.
type Thresholds struct {
	TwoBulk TwoBulkThresholds
	OneBulk OneBulkThresholds
	Z       ZThresholds
}

// ---------------------------------------------------------------------------
// Caches (module-level, shared across all calls within a process)
// ---------------------------------------------------------------------------

var (
	twoBulkCache sync.Map // key: "h_l_hAF_lAF_rep"  → TwoBulkThresholds
	oneBulkCache sync.Map // key: "depth_p0_rep"       → OneBulkThresholds
)

// ---------------------------------------------------------------------------
// Public entry point
// ---------------------------------------------------------------------------

// AddThresholds computes and attaches permutation thresholds to every element
// of smoothed.  It:
//  1. Collects the unique (depth, AF) combinations present in the slice.
//  2. Runs the simulations in parallel (one goroutine per CPU), caching results.
//  3. Attaches TwoBulkThresholds, OneBulkThresholds, and ZThresholds to each
//     SmoothedStats by calling the per-window lookup functions.
//
// cfg.Reps controls the number of permutation draws (e.g. 1000).
// highSmAF / lowSmAF are the genome-wide smoothed allele frequencies used as
// the null distribution for the two-bulk simulation.
// p0 is the expected null high-allele frequency for the one-bulk simulation
// (pass 0 or any value outside (0,1) if there is no one-bulk component).

func AddThresholds(cfg utils.AnalysisConfig, bsaType string, smoothed []SmoothedStats, highSmAF, lowSmAF float64, p0 float64, rep int, ) {
	if len(smoothed) == 0 || rep <= 0 {
		return
	}

	_, _, hasBothBulks, hasOneBulk := bulkFlags(bsaType)

	color.Cyan("\n============================ Calculating Thresholds (%d simulations) ============================\n\n", rep)

	if hasBothBulks {
		calcAllTwoBulkThresholds(smoothed, highSmAF, lowSmAF, rep)
	}
	if hasOneBulk && p0 > 0 && p0 < 1 {
		calcAllOneBulkThresholds(smoothed, p0, rep)
	}

	// Count the number of Z statistics so the composite Z threshold is correct.
	numStats := numZStats(bsaType)

	// Attach per-window thresholds.
	for i := range smoothed {
		sm := &smoothed[i]

		t := Thresholds{}

		if hasBothBulks {
			t.TwoBulk = calcTwoBulkCached(sm.Depth, sm.Depth, highSmAF, lowSmAF, rep)
		}
		if hasOneBulk && p0 > 0 && p0 < 1 {
			t.OneBulk = calcOneBulkCached(sm.Depth, p0, rep)
		}
		t.Z = calcZThresholds(numStats)

		sm.thresholds = t
	}

	color.Green("Threshold calculations complete.\n")
}

// ---------------------------------------------------------------------------
// Z-score thresholds (analytical)
// ---------------------------------------------------------------------------

// calcZThresholds returns standard-normal thresholds for Z-scores and the
// Stouffer composite Z.  Under the null, CompositeZ ~ N(0,1) because each
// contributing Z_i ~ N(0,1) and Stouffer's formula preserves that.
func calcZThresholds(numStats int) ZThresholds {
	const (
		zSig  = 3.0 // ≈ p99 one-sided normal
		zSugg = 2.0 // ≈ p95 one-sided normal
	)
	if numStats < 1 {
		numStats = 1
	}
	return ZThresholds{
		ZP99: zSig, ZP95: zSugg,
		ZN99: -zSig, ZN95: -zSugg,
		CompositeZP99: zSig, CompositeZP95: zSugg,
		CompositeZN99: -zSig, CompositeZN95: -zSugg,
		NumStats: numStats,
	}
}

// numZStats returns the total number of Z statistics that enter the Stouffer
// composite for a given bsaType.  Must stay in sync with consolidate() in
// smoothing.go.
func numZStats(bsaType string) int {
	hasHighBulk, hasLowBulk, hasBothBulks, hasOneBulk := bulkFlags(bsaType)
	n := 0
	if hasHighBulk {
		n++ // ZHighSI
	}
	if hasLowBulk {
		n++ // ZLowSI
	}
	if hasBothBulks {
		n += 5 // ZDeltaSI, ZGstat, ZED, ZLOD, ZBBLogBF
	}
	if hasOneBulk {
		n += 4 // ZAFDev, ZOneBulkG, ZOneBulkLOD, ZOneBulkBBLogBF
	}
	return n
}

// ---------------------------------------------------------------------------
// Two-bulk permutation thresholds
// ---------------------------------------------------------------------------

// calcTwoBulkThresholds runs rep binomial draws for both bulks and returns
// empirical quantile thresholds for every two-bulk statistic.
// Modelled directly on twoBulk.go's calcThresholds, adapted to the stats
// package's function names (GStatistic, euclideanDistance4, lod, betaBinomialLogBF).
func calcTwoBulkThresholds(highBulkDP, lowBulkDP int, highSmAF, lowSmAF float64, rep int) TwoBulkThresholds {
	if highBulkDP <= 0 || lowBulkDP <= 0 || rep <= 0 {
		return TwoBulkThresholds{}
	}

	src := rand.NewSource(time.Now().UnixNano())
	rng := rand.New(src)
	distHigh := distuv.Binomial{N: float64(highBulkDP), P: highSmAF, Src: rng}
	distLow := distuv.Binomial{N: float64(lowBulkDP), P: lowSmAF, Src: rng}

	highSIArr := make([]float64, rep)
	lowSIArr := make([]float64, rep)
	dsiArr := make([]float64, rep)
	gsArr := make([]float64, rep)
	edArr := make([]float64, rep)
	lodArr := make([]float64, rep)
	bbArr := make([]float64, rep)

	for i := 0; i < rep; i++ {
		hAlt := distHigh.Rand()
		lAlt := distLow.Rand()
		hRef := float64(highBulkDP) - hAlt
		lRef := float64(lowBulkDP) - lAlt

		hSI := math.Round((hAlt/float64(highBulkDP))*1e6) / 1e6
		lSI := math.Round((lAlt/float64(lowBulkDP))*1e6) / 1e6

		highSIArr[i] = hSI
		lowSIArr[i] = lSI
		dsiArr[i] = math.Round((hSI-lSI)*1e6) / 1e6
		gsArr[i] = math.Round(GStatistic(int(hAlt), int(hRef), int(lAlt), int(lRef))*1e6) / 1e6
		edArr[i] = math.Round(euclideanDistance4(hSI, lSI)*1e6) / 1e6
		lodArr[i] = math.Round(lod(int(hRef), int(hAlt), int(lRef), int(lAlt))*1e6) / 1e6
		bbArr[i] = math.Round(betaBinomialLogBF(int(hAlt), int(hRef), int(lAlt), int(lRef))*1e6) / 1e6
	}

	sort.Float64s(highSIArr)
	sort.Float64s(lowSIArr)
	sort.Float64s(dsiArr)
	sort.Float64s(gsArr)
	sort.Float64s(edArr)
	sort.Float64s(lodArr)
	sort.Float64s(bbArr)

	r6 := func(v float64) float64 { return math.Round(v*1e6) / 1e6 }
	q := func(arr []float64, p float64) float64 {
		return r6(stat.Quantile(p, stat.Empirical, arr, nil))
	}

	return TwoBulkThresholds{
		HighSIP99:  q(highSIArr, 0.995),
		HighSIP95:  q(highSIArr, 0.95),
		HighSIMp99: q(highSIArr, 0.005),
		HighSIMp95: q(highSIArr, 0.05),

		LowSIP99:  q(lowSIArr, 0.995),
		LowSIP95:  q(lowSIArr, 0.95),
		LowSIMp99: q(lowSIArr, 0.005),
		LowSIMp95: q(lowSIArr, 0.05),

		DeltaSIP99:  q(dsiArr, 0.995),
		DeltaSIP95:  q(dsiArr, 0.95),
		DeltaSIMp99: q(dsiArr, 0.005),
		DeltaSIMp95: q(dsiArr, 0.05),

		GstatP99: q(gsArr, 0.995),
		GstatP95: q(gsArr, 0.95),

		ED4P99: q(edArr, 0.995),
		ED4P95: q(edArr, 0.95),

		LODP99: q(lodArr, 0.995),
		LODP95: q(lodArr, 0.95),

		BBLogBFP99: q(bbArr, 0.995),
		BBLogBFP95: q(bbArr, 0.95),
	}
}

// calcTwoBulkCached is the cached wrapper for calcTwoBulkThresholds.
func calcTwoBulkCached(highBulkDP, lowBulkDP int, highSmAF, lowSmAF float64, rep int) TwoBulkThresholds {
	key := fmt.Sprintf("%d_%d_%.6f_%.6f_%d", highBulkDP, lowBulkDP, highSmAF, lowSmAF, rep)
	if v, ok := twoBulkCache.Load(key); ok {
		return v.(TwoBulkThresholds)
	}
	t := calcTwoBulkThresholds(highBulkDP, lowBulkDP, highSmAF, lowSmAF, rep)
	actual, _ := twoBulkCache.LoadOrStore(key, t)
	return actual.(TwoBulkThresholds)
}

// calcAllTwoBulkThresholds pre-warms the two-bulk cache for every unique
// depth combination present in smoothed.  Computations run in parallel.
func calcAllTwoBulkThresholds(smoothed []SmoothedStats, highSmAF, lowSmAF float64, rep int) {
	type depthKey struct{ depth int }
	seen := make(map[depthKey]bool)
	for _, sm := range smoothed {
		if sm.Depth > 0 {
			seen[depthKey{sm.Depth}] = true
		}
	}

	keys := make([]depthKey, 0, len(seen))
	for k := range seen {
		keys = append(keys, k)
	}
	if len(keys) == 0 {
		return
	}

	bar := progressbar.NewOptions(len(keys),
		progressbar.OptionSetDescription("Computing two-bulk thresholds"),
		progressbar.OptionSetWidth(40),
		progressbar.OptionShowCount(),
		progressbar.OptionSetTheme(progressbar.Theme{
			Saucer: "=", SaucerHead: ">", SaucerPadding: " ",
			BarStart: "[", BarEnd: "]",
		}),
	)

	keyChan := make(chan depthKey, len(keys))
	for _, k := range keys {
		keyChan <- k
	}
	close(keyChan)

	var wg sync.WaitGroup
	for w := 0; w < runtime.NumCPU(); w++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for k := range keyChan {
				// Use depth for both bulks; if the caller has separate high/low
				// depths they can call calcTwoBulkCached directly.
				calcTwoBulkCached(k.depth, k.depth, highSmAF, lowSmAF, rep)
				_ = bar.Add(1)
			}
		}()
	}
	wg.Wait()
	fmt.Println()
}

// ---------------------------------------------------------------------------
// One-bulk permutation thresholds
// ---------------------------------------------------------------------------

// calcOneBulkThresholds runs rep binomial draws for a single bulk at the null
// allele frequency p0 and returns empirical quantile thresholds for all
// one-bulk statistics.
func calcOneBulkThresholds(depth int, p0 float64, rep int) OneBulkThresholds {
	if depth <= 0 || p0 <= 0 || p0 >= 1 || rep <= 0 {
		return OneBulkThresholds{}
	}

	src := rand.NewSource(time.Now().UnixNano())
	rng := rand.New(src)
	dist := distuv.Binomial{N: float64(depth), P: p0, Src: rng}

	afDevArr := make([]float64, rep)
	gsArr := make([]float64, rep)
	lodArr := make([]float64, rep)
	bbArr := make([]float64, rep)

	for i := 0; i < rep; i++ {
		succF := dist.Rand()
		succ := int(succF)
		fail := depth - succ

		si := math.Round((succF/float64(depth))*1e6) / 1e6

		afDevArr[i] = math.Round((si-p0)*1e6) / 1e6
		gsArr[i] = math.Round(oneBulkGStatistic(succ, fail, p0)*1e6) / 1e6
		lodArr[i] = math.Round(oneBulkLOD(succ, fail, p0)*1e6) / 1e6
		bbArr[i] = math.Round(oneBulkBetaBinomialLogBF(succ, fail, p0)*1e6) / 1e6
	}

	sort.Float64s(afDevArr)
	sort.Float64s(gsArr)
	sort.Float64s(lodArr)
	sort.Float64s(bbArr)

	r6 := func(v float64) float64 { return math.Round(v*1e6) / 1e6 }
	q := func(arr []float64, p float64) float64 {
		return r6(stat.Quantile(p, stat.Empirical, arr, nil))
	}

	return OneBulkThresholds{
		AFDevP99:  q(afDevArr, 0.995),
		AFDevP95:  q(afDevArr, 0.95),
		AFDevMp99: q(afDevArr, 0.005),
		AFDevMp95: q(afDevArr, 0.05),

		OneBulkGstatP99: q(gsArr, 0.995),
		OneBulkGstatP95: q(gsArr, 0.95),

		OneBulkLODP99: q(lodArr, 0.995),
		OneBulkLODP95: q(lodArr, 0.95),

		OneBulkBBLogBFP99: q(bbArr, 0.995),
		OneBulkBBLogBFP95: q(bbArr, 0.95),
	}
}

// calcOneBulkCached is the cached wrapper for calcOneBulkThresholds.
func calcOneBulkCached(depth int, p0 float64, rep int) OneBulkThresholds {
	key := fmt.Sprintf("%d_%.6f_%d", depth, p0, rep)
	if v, ok := oneBulkCache.Load(key); ok {
		return v.(OneBulkThresholds)
	}
	t := calcOneBulkThresholds(depth, p0, rep)
	actual, _ := oneBulkCache.LoadOrStore(key, t)
	return actual.(OneBulkThresholds)
}

// calcAllOneBulkThresholds pre-warms the one-bulk cache for every unique
// depth value present in smoothed.  Computations run in parallel.
func calcAllOneBulkThresholds(smoothed []SmoothedStats, p0 float64, rep int) {
	seen := make(map[int]bool)
	for _, sm := range smoothed {
		if sm.Depth > 0 {
			seen[sm.Depth] = true
		}
	}

	depths := make([]int, 0, len(seen))
	for d := range seen {
		depths = append(depths, d)
	}
	if len(depths) == 0 {
		return
	}

	bar := progressbar.NewOptions(len(depths),
		progressbar.OptionSetDescription("Computing one-bulk thresholds"),
		progressbar.OptionSetWidth(40),
		progressbar.OptionShowCount(),
		progressbar.OptionSetTheme(progressbar.Theme{
			Saucer: "=", SaucerHead: ">", SaucerPadding: " ",
			BarStart: "[", BarEnd: "]",
		}),
	)

	depthChan := make(chan int, len(depths))
	for _, d := range depths {
		depthChan <- d
	}
	close(depthChan)

	var wg sync.WaitGroup
	for w := 0; w < runtime.NumCPU(); w++ {
		wg.Add(1)
		go func() {
			defer wg.Done()
			for d := range depthChan {
				calcOneBulkCached(d, p0, rep)
				_ = bar.Add(1)
			}
		}()
	}
	wg.Wait()
	fmt.Println()
}
